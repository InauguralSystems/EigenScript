# Fibonacci тААФ recursive and iterative
# Demonstrates: functions, recursion, loops, lists

# Recursive
define fib_rec as:
    if n <= 1:
        return n
    return (fib_rec of (n -  1)) + (fib_rec of (n -- 2))

print of ("fib(10) reucrsive: " + (str of (fib_rec of 10)))

