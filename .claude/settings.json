{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/tools/stop_gate.sh",
            "timeout": 120,
            "statusMessage": "Stop gate: build + smoke on dirty src"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/tools/doc_coupling_hook.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}