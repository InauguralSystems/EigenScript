# ============================================================
# Math Library — numeric utilities in pure EigenScript
# ============================================================
#
# How to use:
#   load_file of "lib/math.eigs"
#
#   abs of -5                       # 5
#   sign of -5                      # -1
#   max_val of [3, 1, 4, 1, 5]     # 5
#   min_val of [3, 1, 4, 1, 5]     # 1
#   clamp of [15, 0, 10]           # 10
#   lerp of [0, 100, 0.25]         # 25
#   dot of [[1,2,3], [4,5,6]]      # 32
#   gcd of [12, 18]                 # 6
#   lcm of [4, 6]                   # 12

# ---- abs: absolute value ----
# abs of value -> number
define abs(x) as:
    if x < 0:
        return 0 - x
    return x

# ---- sign: return -1, 0, or 1 ----
# sign of value -> number
define sign(x) as:
    if x < 0:
        return -1
    if x > 0:
        return 1
    return 0

# ---- max_val: maximum element in a list ----
# max_val of list -> number
define max_val(items) as:
    if (len of items) < 1:
        return 0
    best is items[0]
    for i in range of (len of items):
        if items[i] > best:
            best is items[i]
    return best

# ---- min_val: minimum element in a list ----
# min_val of list -> number
define min_val(items) as:
    if (len of items) < 1:
        return 0
    best is items[0]
    for i in range of (len of items):
        if items[i] < best:
            best is items[i]
    return best

# ---- clamp: restrict value to [lo, hi] ----
# clamp of [value, lo, hi] -> number
define clamp(val, lo, hi) as:
    if val < lo:
        return lo
    if val > hi:
        return hi
    return val

# ---- lerp: linear interpolation between a and b ----
# lerp of [a, b, t] -> number (a + (b-a)*t)
define lerp(a, b, t) as:
    return a + (b - a) * t

# ---- dot: dot product of two 1D lists ----
# dot of [list_a, list_b] -> number
# Iterates over min(len a, len b) to match zip's shorter-wins behavior
# and avoid out-of-bounds access when the lists have different lengths.
define dot(a, b) as:
    la is len of a
    lb is len of b
    n is la
    if lb < n:
        n is lb
    result is 0
    for i in range of n:
        result is result + a[i] * b[i]
    return result

# ---- gcd: greatest common divisor (Euclid's algorithm) ----
# gcd of [a, b] -> number
# Always returns a non-negative result.
define gcd(a, b) as:
    if a < 0:
        a is 0 - a
    if b < 0:
        b is 0 - b
    loop while b > 0:
        t is b
        b is a % b
        a is t
    return a

# ---- lcm: least common multiple ----
# lcm of [a, b] -> number
# Defined in terms of gcd. Returns 0 if either input is 0.
define lcm(a, b) as:
    if a == 0 or b == 0:
        return 0
    if a < 0:
        a is 0 - a
    if b < 0:
        b is 0 - b
    return (a / (gcd of [a, b])) * b

# ---- argmax: index of the largest element ----
# argmax of list -> int (index of max, -1 if empty)
# On ties returns the first (leftmost) index — strict > only updates.
define argmax(items) as:
    if (len of items) == 0:
        return -1
    best_idx is 0
    best_val is items[0]
    for i in range of (len of items):
        if items[i] > best_val:
            best_val is items[i]
            best_idx is i
    return best_idx

# ---- argmin: index of the smallest element ----
# argmin of list -> int (index of min, -1 if empty)
# On ties returns the first (leftmost) index — strict < only updates.
define argmin(items) as:
    if (len of items) == 0:
        return -1
    best_idx is 0
    best_val is items[0]
    for i in range of (len of items):
        if items[i] < best_val:
            best_val is items[i]
            best_idx is i
    return best_idx

# ---- log2: base-2 logarithm ----
# log2 of value -> number
# Domain follows the log builtin: input is floored at 1e-10.
define log2(x) as:
    return (log of x) / 0.6931471805599453

# ---- log10: base-10 logarithm ----
# log10 of value -> number
# Domain follows the log builtin: input is floored at 1e-10.
define log10(x) as:
    return (log of x) / 2.302585092994046
