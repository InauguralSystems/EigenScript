# ============================================================
# UI Toolkit Unit Tests — layout, hit-testing, focus, registry
# ============================================================
# Runs without SDL2 by stubbing gfx_* functions.

load_file of "lib/test.eigs"

# ---- Stub gfx functions (no-ops for headless testing) ----

define gfx_open(args) as:
    return 1

define gfx_close(args) as:
    return null

define gfx_clear(args) as:
    return null

define gfx_rect(args) as:
    return null

define gfx_rrect(args) as:
    return null

define gfx_line(args) as:
    return null

define gfx_point(args) as:
    return null

define gfx_circle(args) as:
    return null

define gfx_text(args) as:
    return null

define gfx_clip(args) as:
    return null

define gfx_present(args) as:
    return null

define gfx_poll(args) as:
    return null

define gfx_delay(args) as:
    return null

define gfx_ticks(args) as:
    return 1000

# Metrics stubs mirror the bitmap-font math (#593) so every layout
# assertion below keeps its historical value regardless of the fonts
# installed on the machine running the suite.
define gfx_text_width(text, scale) as:
    return (len of text) * 6 * scale

define gfx_text_height(scale) as:
    return 7 * scale

# ---- Load UI toolkit ----

load_file of "lib/ui.eigs"

print of "=== UI Toolkit Tests ==="

# ============================================================
# 1. Constructor tests
# ============================================================

print of "--- Constructor Tests ---"

b is button of ["btn1", 10, 20, 80, 30, "Click", null]
assert_eq of [b.type, "button", "button type"]
assert_eq of [b.id, "btn1", "button id"]
assert_eq of [b.x, 10, "button x"]
assert_eq of [b.y, 20, "button y"]
assert_eq of [b.w, 80, "button w"]
assert_eq of [b.h, 30, "button h"]
assert_eq of [b.label, "Click", "button label"]
assert_eq of [b.hover, 0, "button hover default"]
assert_eq of [b.pressed, 0, "button pressed default"]
assert_eq of [b.enabled, 1, "button enabled default"]
assert_eq of [b.visible, 1, "button visible default"]

s is slider of ["sl1", 5, 10, 200, 0, 100, 50, null]
assert_eq of [s.type, "slider", "slider type"]
assert_eq of [s.value, 50, "slider value"]
assert_eq of [s.min_val, 0, "slider min"]
assert_eq of [s.max_val, 100, "slider max"]

p is panel of ["pan1", 0, 0, 400, 300]
assert_eq of [p.type, "panel", "panel type"]
assert_eq of [len of p.children, 0, "panel empty children"]

lbl is label of ["lbl1", 10, 10, "Hello"]
assert_eq of [lbl.type, "label", "label type"]
assert_eq of [lbl.text, "Hello", "label text"]

t is toggle of ["tog1", 0, 0, 0, null]
assert_eq of [t.type, "toggle", "toggle type"]
assert_eq of [t.value, 0, "toggle default off"]

# ---- Per-widget button colors (#566) ----
# Render every state with custom bg/text_color set: the render path must
# not error (gfx stubs are no-ops) and must not clobber the overrides.
bc is button of ["btnc", 0, 0, 80, 24, "Rec", null]
bc.bg is [200, 40, 40]
bc.text_color is [255, 255, 255]
_render_button of [bc, 0, 0]
bc.hover is 1
_render_button of [bc, 0, 0]
bc.pressed is 1
_render_button of [bc, 0, 0]
bc.enabled is 0
_render_button of [bc, 0, 0]
assert_eq of [bc.bg[0], 200, "custom button bg preserved across renders"]
assert_eq of [bc.text_color[0], 255, "custom button text color preserved"]
bd is button of ["btnd", 0, 0, 80, 24, "Plain", null]
bd.hover is 1
_render_button of [bd, 0, 0]
assert_eq of [bd.bg, null, "plain button has no bg override"]

# ============================================================
# 2. Registry tests
# ============================================================

print of "--- Registry Tests ---"

# Widget types are registered
assert_true of [_widget_registry["button"] != null, "button registered"]
assert_true of [_widget_registry["slider"] != null, "slider registered"]
assert_true of [_widget_registry["panel"] != null, "panel registered"]
assert_true of [_widget_registry["tabs"] != null, "tabs registered"]
assert_true of [_widget_registry["table"] != null, "table registered"]

# Container flag
assert_eq of [_widget_registry["panel"].container, 1, "panel is container"]
assert_eq of [_widget_registry["hbox"].container, 1, "hbox is container"]
assert_eq of [_widget_registry["button"].container, 0, "button not container"]
assert_eq of [_widget_registry["slider"].container, 0, "slider not container"]

# Focusable flag
assert_eq of [_widget_registry["button"].focusable, 1, "button focusable"]
assert_eq of [_widget_registry["slider"].focusable, 1, "slider focusable"]
assert_eq of [_widget_registry["label"].focusable, 0, "label not focusable"]
assert_eq of [_widget_registry["separator"].focusable, 0, "separator not focusable"]

# _is_container uses registry
assert_eq of [_is_container of "panel", 1, "_is_container panel"]
assert_eq of [_is_container of "vbox", 1, "_is_container vbox"]
assert_eq of [_is_container of "button", 0, "_is_container button"]

# ============================================================
# 3. Layout tests
# ============================================================

print of "--- Layout Tests ---"

# hbox with 3 children of equal width
root is panel of ["root", 0, 0, 300, 100]
hb is hbox of ["hb", 0, 0, 300, 50]
hb.gap is 0
hb.padding is 0
c1 is button of ["c1", 0, 0, 100, 30, "A", null]
c2 is button of ["c2", 0, 0, 100, 30, "B", null]
c3 is button of ["c3", 0, 0, 100, 30, "C", null]
add_child of [hb, c1]
add_child of [hb, c2]
add_child of [hb, c3]
add_child of [root, hb]

_layout of [root, 0, 0]

assert_eq of [c1.x, 0, "hbox child1 x"]
assert_eq of [c2.x, 100, "hbox child2 x"]
assert_eq of [c3.x, 200, "hbox child3 x"]

# vbox with gap
root2 is panel of ["root2", 0, 0, 200, 400]
vb is vbox of ["vb", 10, 10, 200, 300]
vb.gap is 10
vb.padding is 5
v1 is button of ["v1", 0, 0, 80, 30, "X", null]
v2 is button of ["v2", 0, 0, 80, 30, "Y", null]
add_child of [vb, v1]
add_child of [vb, v2]
add_child of [root2, vb]

_layout of [root2, 0, 0]

assert_eq of [v1.y, 5, "vbox child1 y (padding)"]
assert_eq of [v2.y, 45, "vbox child2 y (30h + 10gap + 5pad)"]

# Cached absolute positions
assert_eq of [root2._ax, 0, "root _ax"]
assert_eq of [root2._ay, 0, "root _ay"]
assert_eq of [vb._ax, 10, "vbox _ax"]
assert_eq of [vb._ay, 10, "vbox _ay"]
assert_eq of [v1._ax, 15, "vbox child1 _ax (10 + 5pad)"]
assert_eq of [v1._ay, 15, "vbox child1 _ay (10 + 5pad)"]

# ============================================================
# 4. Hit-test tests
# ============================================================

print of "--- Hit-Test Tests ---"

# Build a simple tree
hr is panel of ["hr", 0, 0, 400, 300]
hb1 is button of ["hb1", 10, 10, 80, 30, "Hit", null]
hb2 is button of ["hb2", 100, 10, 80, 30, "Miss", null]
add_child of [hr, hb1]
add_child of [hr, hb2]

_layout of [hr, 0, 0]

# Hit inside button 1
result is _hit_test of [hr, 0, 0, 50, 25]
assert_true of [result != null, "hit test finds widget"]
assert_eq of [result.id, "hb1", "hit test correct widget"]

# Hit inside button 2
result is _hit_test of [hr, 0, 0, 140, 25]
assert_true of [result != null, "hit test button 2"]
assert_eq of [result.id, "hb2", "hit test button 2 id"]

# Miss — empty area
result is _hit_test of [hr, 0, 0, 250, 250]
assert_true of [result == null, "hit test miss returns null"]

# Hit test respects visibility
hb1.visible is 0
result is _hit_test of [hr, 0, 0, 50, 25]
assert_true of [result == null, "invisible widget not hit"]
hb1.visible is 1

# ============================================================
# 5. Focus tests
# ============================================================

print of "--- Focus Tests ---"

# Build tree: panel > [button, label, slider, button]
fp is panel of ["fp", 0, 0, 400, 200]
fb1 is button of ["fb1", 10, 10, 60, 24, "A", null]
fl is label of ["fl", 80, 10, "Text"]
fs is slider of ["fs", 10, 50, 200, 0, 100, 50, null]
fb2 is button of ["fb2", 10, 80, 60, 24, "B", null]
add_child of [fp, fb1]
add_child of [fp, fl]
add_child of [fp, fs]
add_child of [fp, fb2]

_layout of [fp, 0, 0]

_ui.focus_list is []
_build_focus_list of fp
assert_eq of [len of _ui.focus_list, 3, "focus list skips label (3 focusable)"]
assert_eq of [_ui.focus_list[0].id, "fb1", "focus list[0] = button 1"]
assert_eq of [_ui.focus_list[1].id, "fs", "focus list[1] = slider"]
assert_eq of [_ui.focus_list[2].id, "fb2", "focus list[2] = button 2"]

# Focus cycling
_ui.focus_index is -1
_ui.focused_widget is null
_ui.focused_input is null
_focus_next of [fp, 0]
assert_eq of [_ui.focused_widget.id, "fb1", "focus next -> button 1"]

_focus_next of [fp, 0]
assert_eq of [_ui.focused_widget.id, "fs", "focus next -> slider"]

_focus_next of [fp, 0]
assert_eq of [_ui.focused_widget.id, "fb2", "focus next -> button 2"]

_focus_next of [fp, 0]
assert_eq of [_ui.focused_widget.id, "fb1", "focus wraps to button 1"]

# Reverse
_focus_next of [fp, 1]
assert_eq of [_ui.focused_widget.id, "fb2", "focus prev wraps to button 2"]

# Disabled widget skipped
fs.enabled is 0
_ui.focus_list is []
_build_focus_list of fp
assert_eq of [len of _ui.focus_list, 2, "disabled slider not in focus list"]
fs.enabled is 1

# ============================================================
# 6. Scroll tests
# ============================================================

print of "--- Scroll Tests ---"

sp is scroll_panel of ["sp", 0, 0, 200, 100]
sp.content_h is 500

_layout of [sp, 0, 0]

# Scroll down
_scroll_panels of [sp, 0, 60]
assert_eq of [sp.scroll_y, 60, "scroll down 60"]

# Scroll past max
_scroll_panels of [sp, 0, 500]
assert_eq of [sp.scroll_y, 400, "scroll clamped to max (500-100)"]

# Scroll back up past 0
_scroll_panels of [sp, 0, -9999]
assert_eq of [sp.scroll_y, 0, "scroll clamped to 0"]

# Item list scroll
il is item_list of ["il", 0, 0, 100, 60, ["a", "b", "c", "d", "e"], null]

_layout of [il, 0, 0]

_scroll_panels of [il, 0, 30]
assert_eq of [il.scroll_y, 30, "item_list scroll down"]

_scroll_panels of [il, 0, 999]
max_expected is (len of il.items) * il.item_h - il.h
assert_eq of [il.scroll_y, max_expected, "item_list scroll clamped"]

_scroll_panels of [il, 0, -9999]
assert_eq of [il.scroll_y, 0, "item_list scroll min 0"]

# ============================================================
# 7. Keyboard accessibility — 10 new focusable types
# ============================================================

print of "--- Keyboard Accessibility Tests ---"

# Build tree with all 10 new focusable types
kp is panel of ["kp", 0, 0, 800, 600]
add_child of [kp, canvas of ["kc", 0, 0, 100, 100, null, null]]
add_child of [kp, editable_label of ["kel", 0, 0, "edit", null]]
add_child of [kp, grid of ["kg", 0, 0, 4, 4, 20, 20, null]]
add_child of [kp, chart of ["kch", 0, 0, 200, 100]]
add_child of [kp, bar_chart of ["kbc", 0, 0, 200, 100, ["a"], [1], null]]
add_child of [kp, gauge of ["kga", 0, 0, 60, 0, 100, 50, ""]]
add_child of [kp, code_view of ["kcv", 0, 0, 200, 100, "hello"]]
add_child of [kp, color_picker of ["kcp", 0, 0, null]]
add_child of [kp, waveform_view of ["kwv", 0, 0, 200, 100]]
add_child of [kp, piano_keyboard of ["kpk", 0, 0, 2, null]]

_layout of [kp, 0, 0]

_ui.focus_list is []
_build_focus_list of kp
assert_eq of [len of _ui.focus_list, 10, "all 10 new types in focus list"]

# Verify specific types are present
found_canvas is 0
found_grid is 0
found_chart is 0
found_gauge is 0
found_color_picker is 0
for i in range of (len of _ui.focus_list):
    if _ui.focus_list[i].type == "canvas":
        found_canvas is 1
    if _ui.focus_list[i].type == "grid":
        found_grid is 1
    if _ui.focus_list[i].type == "chart":
        found_chart is 1
    if _ui.focus_list[i].type == "gauge":
        found_gauge is 1
    if _ui.focus_list[i].type == "color_picker":
        found_color_picker is 1
assert_eq of [found_canvas, 1, "canvas focusable"]
assert_eq of [found_grid, 1, "grid focusable"]
assert_eq of [found_chart, 1, "chart focusable"]
assert_eq of [found_gauge, 1, "gauge focusable"]
assert_eq of [found_color_picker, 1, "color_picker focusable"]

# Grid keyboard: arrow moves hover
g is grid of ["tg", 0, 0, 4, 4, 20, 20, null]
g.hover_row is 1
g.hover_col is 1
_ui.focused_widget is g
_handle_focus_key of [kp, {"key": "right", "shift": 0, "ctrl": 0, "alt": 0}]
assert_eq of [g.hover_col, 2, "grid right arrow"]
_handle_focus_key of [kp, {"key": "down", "shift": 0, "ctrl": 0, "alt": 0}]
assert_eq of [g.hover_row, 2, "grid down arrow"]

# Grid keyboard: space toggles cell
_handle_focus_key of [kp, {"key": "space", "shift": 0, "ctrl": 0, "alt": 0}]
assert_eq of [g.cells[2][2], 1, "grid space toggles on"]
_handle_focus_key of [kp, {"key": "space", "shift": 0, "ctrl": 0, "alt": 0}]
assert_eq of [g.cells[2][2], 0, "grid space toggles off"]

# Editable label: enter starts editing
el is editable_label of ["tel", 0, 0, "test", null]
_ui.focused_widget is el
_handle_focus_key of [kp, {"key": "return", "shift": 0, "ctrl": 0, "alt": 0}]
assert_eq of [el.editing, 1, "editable_label enter starts editing"]

# ============================================================
# 8. Canvas raw-event seam + drag capture (#567)
# ============================================================
# NOTE: the gfx_ticks stub above returns a constant, so every repeat
# mousedown on the SAME widget id reads as a double-click and skips the
# registry mousedown path — reset _ui.last_click_id between gestures.

print of "--- Canvas Event Seam Tests (#567) ---"

cv_seen is []
define cv_on_mouse(w, ev) as:
    append of [cv_seen, ev.type]
    if ev.type == "mousedown":
        claim_drag of w

cvroot is panel of ["cvroot", 0, 0, 400, 300]
cv is canvas of ["cv", 10, 10, 300, 200, null, cv_on_mouse]
add_child of [cvroot, cv]
_layout of [cvroot, 0, 0]

# Hover mousemove (no button) reaches on_mouse
dispatch of [cvroot, {"type": "mousemove", "x": 60, "y": 60}]
assert_eq of [len of cv_seen, 1, "hover mousemove delivered to canvas on_mouse"]
assert_eq of [cv_seen[0], "mousemove", "hover event type is mousemove"]

# Full press-move-release gesture with capture (the #567 repro)
cv_seen is []
dispatch of [cvroot, {"type": "mousedown", "x": 50, "y": 50, "button": 1}]
assert_true of [_ui.drag_widget != null, "canvas claimed the pointer via claim_drag"]
dispatch of [cvroot, {"type": "mousemove", "x": 80, "y": 60}]
dispatch of [cvroot, {"type": "mousemove", "x": 120, "y": 70}]
dispatch of [cvroot, {"type": "mouseup", "x": 120, "y": 70, "button": 1}]
assert_eq of [len of cv_seen, 4, "canvas saw all 4 gesture events"]
assert_eq of [cv_seen[0], "mousedown", "gesture event 0 = mousedown"]
assert_eq of [cv_seen[1], "mousemove", "drag mousemove delivered while captured"]
assert_eq of [cv_seen[3], "mouseup", "terminating mouseup delivered to canvas"]
assert_true of [_ui.drag_widget == null, "capture released on mouseup"]

# Modifier fields ride along on the event dict (#568 contract)
cv_mods is []
define cv_mod_mouse(w, ev) as:
    append of [cv_mods, ev.shift]
    append of [cv_mods, ev.ctrl]
cv.on_mouse is cv_mod_mouse
_ui.last_click_id is ""
dispatch of [cvroot, {"type": "mousedown", "x": 50, "y": 50, "button": 1, "shift": 1, "ctrl": 0}]
assert_eq of [cv_mods[0], 1, "ev.shift passes through dispatch to on_mouse"]
assert_eq of [cv_mods[1], 0, "ev.ctrl passes through dispatch to on_mouse"]
_ui.drag_widget is null

# Sharp edge (#567): a claimant with no drag handler and no on_mouse is
# a silent no-op — this used to throw type_mismatch in the slider updater.
cv0 is canvas of ["cv0", 10, 10, 100, 100, null, null]
claim_drag of cv0
dispatch of [cvroot, {"type": "mousemove", "x": 100, "y": 60}]
assert_true of [_ui.drag_widget != null, "handler-less claimant keeps capture, no throw"]
release_drag of null
assert_true of [_ui.drag_widget == null, "release_drag clears capture"]

# ============================================================
# 9. Registry-driven drag back-compat (built-in draggable types)
# ============================================================

print of "--- Drag Registry Back-compat Tests ---"

dr is panel of ["dr", 0, 0, 400, 300]
sl_changes is 0
define on_sl_change(w) as:
    sl_changes is sl_changes + 1
dsl is slider of ["dsl", 10, 10, 200, 0, 100, 0, on_sl_change]
dvs is vslider of ["dvs", 10, 50, 100, 0, 100, 0, null]
dkn is knob of ["dkn", 250, 10, 40, 0, 100, 50, null]
dsb is scrollbar of ["dsb", 10, 200, 200, 0, null]
dwv is waveform_view of ["dwv", 10, 220, 200, 60]
dwv.zoom is 2.0
dwv.offset is 100
dcp is color_picker of ["dcp", 220, 60, null]
add_child of [dr, dsl]
add_child of [dr, dvs]
add_child of [dr, dkn]
add_child of [dr, dsb]
add_child of [dr, dwv]
add_child of [dr, dcp]
_layout of [dr, 0, 0]

# slider: press, drag, release
dispatch of [dr, {"type": "mousedown", "x": 60, "y": 18, "button": 1}]
assert_eq of [dsl.value, 25, "slider mousedown sets value"]
dispatch of [dr, {"type": "mousemove", "x": 110, "y": 18}]
assert_eq of [dsl.value, 50, "slider drag updates value via registry on_drag"]
dispatch of [dr, {"type": "mouseup", "x": 110, "y": 18, "button": 1}]
assert_eq of [dsl.dragging, 0, "slider dragging cleared on release"]
assert_true of [_ui.drag_widget == null, "slider capture released"]
assert_eq of [sl_changes, 3, "slider on_change fired on press+drag+release"]

# vslider
dispatch of [dr, {"type": "mousedown", "x": 18, "y": 100, "button": 1}]
dispatch of [dr, {"type": "mousemove", "x": 18, "y": 75}]
assert_eq of [dvs.value, 75, "vslider drag updates value"]
dispatch of [dr, {"type": "mouseup", "x": 18, "y": 75, "button": 1}]

# knob (vertical relative drag)
dispatch of [dr, {"type": "mousedown", "x": 260, "y": 30, "button": 1}]
dispatch of [dr, {"type": "mousemove", "x": 260, "y": 10}]
assert_near of [dkn.value, 60, 0.0001, "knob drag updates value"]
dispatch of [dr, {"type": "mouseup", "x": 260, "y": 10, "button": 1}]

# scrollbar (horizontal)
dispatch of [dr, {"type": "mousedown", "x": 60, "y": 206, "button": 1}]
dispatch of [dr, {"type": "mousemove", "x": 100, "y": 206}]
assert_eq of [dsb.value, 0.4375, "scrollbar drag updates value"]
dispatch of [dr, {"type": "mouseup", "x": 100, "y": 206, "button": 1}]

# waveform_view (sample-space selection)
dispatch of [dr, {"type": "mousedown", "x": 60, "y": 240, "button": 1}]
assert_eq of [dwv.sel_start, 200, "waveform mousedown sets sel_start"]
dispatch of [dr, {"type": "mousemove", "x": 110, "y": 240}]
assert_eq of [dwv.sel_end, 300, "waveform drag extends sel_end"]
dispatch of [dr, {"type": "mouseup", "x": 110, "y": 240, "button": 1}]

# color_picker (SV square)
dispatch of [dr, {"type": "mousedown", "x": 270, "y": 90, "button": 1}]
dispatch of [dr, {"type": "mousemove", "x": 295, "y": 120}]
assert_eq of [dcp.sat, 0.5, "color_picker drag updates sat"]
assert_eq of [dcp.val, 0.5, "color_picker drag updates val"]
dispatch of [dr, {"type": "mouseup", "x": 295, "y": 120, "button": 1}]

# splitter (own root; hit is the divider bar)
spl_resizes is 0
define on_spl_resize(w) as:
    spl_resizes is spl_resizes + 1
sroot is panel of ["sroot", 0, 0, 400, 100]
spl is splitter of ["spl", 0, 0, 400, 100, 100, on_spl_resize]
add_child of [sroot, spl]
_layout of [sroot, 0, 0]
dispatch of [sroot, {"type": "mousedown", "x": 102, "y": 50, "button": 1}]
dispatch of [sroot, {"type": "mousemove", "x": 150, "y": 50}]
assert_eq of [spl.split_pos, 150, "splitter drag moves split_pos"]
assert_eq of [spl_resizes, 1, "splitter on_resize fired during drag"]
dispatch of [sroot, {"type": "mouseup", "x": 150, "y": 50, "button": 1}]

# ============================================================
# 10. Wheel seam (#569)
# ============================================================

print of "--- Wheel Seam Tests (#569) ---"

wheel_seen is []
define cv_on_wheel(w, ev) as:
    append of [wheel_seen, ev.y]
    append of [wheel_seen, ev.ctrl]

wroot is panel of ["wroot", 0, 0, 400, 300]
wsp is scroll_panel of ["wsp", 0, 0, 200, 100]
wsp.content_h is 300
wcv is canvas of ["wcv", 0, 0, 200, 300, null, null]
wcv.on_wheel is cv_on_wheel
add_child of [wsp, wcv]
add_child of [wroot, wsp]
_layout of [wroot, 0, 0]

# Position the cursor over the canvas, then wheel: on_wheel consumes it
dispatch of [wroot, {"type": "mousemove", "x": 50, "y": 50}]
dispatch of [wroot, {"type": "wheel", "x": 0, "y": -3, "ctrl": 1}]
assert_eq of [len of wheel_seen, 2, "canvas on_wheel received the event"]
assert_eq of [wheel_seen[0], -3, "on_wheel sees the y delta"]
assert_eq of [wheel_seen[1], 1, "on_wheel sees ctrl modifier (#568 pairing)"]
assert_eq of [wsp.scroll_y, 0, "consumed wheel does not scroll the enclosing panel"]

# Without on_wheel the scrollable walk handles it as before
wcv.on_wheel is null
dispatch of [wroot, {"type": "wheel", "x": 0, "y": -3}]
assert_eq of [wsp.scroll_y, 60, "wheel falls through to scroll_panel when unconsumed"]

# ============================================================
# 11. scroll_panel child _ax/_ay account for scroll offset (#569)
# ============================================================

print of "--- Scroll Offset Cache Tests (#569) ---"

sp3 is scroll_panel of ["sp3", 0, 0, 200, 100]
sp3.content_h is 300
sp3.content_w is 400
cv3 is canvas of ["cv3", 0, 0, 400, 300, null, null]
add_child of [sp3, cv3]
_layout of [sp3, 0, 0]
assert_eq of [cv3._ay, 0, "unscrolled child _ay"]
sp3.scroll_y is 50
sp3.scroll_x is 30
_layout of [sp3, 0, 0]
assert_eq of [cv3._ay, 0 - 50, "child _ay accounts for scroll_y"]
assert_eq of [cv3._ax, 0 - 30, "child _ax accounts for scroll_x"]

# ============================================================
# 12. Keyboard routing through dispatch (#563)
# ============================================================

print of "--- Keyboard Routing Tests (#563) ---"

# Earlier sections leave focus state behind; these assertions are about
# routing, so start from a known-clear focus.
_ui.focused_input is null
_ui.focused_widget is null

kroot is panel of ["kroot", 0, 0, 800, 600]
hk_fired is [0]
define hk_cb() as:
    hk_fired[0] is hk_fired[0] + 1

register_hotkey of ["ctrl+s", hk_cb]
consumed is dispatch of [kroot, {"type": "keydown", "key": "s", "ctrl": 1, "shift": 0, "alt": 0}]
assert_eq of [hk_fired[0], 1, "hotkey fires through the public dispatch door"]
assert_eq of [consumed, 1, "dispatch reports the hotkey as consumed"]

# A key the toolkit does not claim is reported free for the app. Focus
# navigation reports its own consumption, so an unbound letter is free
# even while a widget holds focus.
free is dispatch of [kroot, {"type": "keydown", "key": "j", "ctrl": 0, "shift": 0, "alt": 0}]
assert_eq of [free, 0, "unclaimed key reported unconsumed"]

# handle_key is the same door app_loop uses — priority is pinned here
# rather than duplicated inside the loop.
hk2 is handle_key of [kroot, {"type": "keydown", "key": "s", "ctrl": 1, "shift": 0, "alt": 0}]
assert_eq of [hk2, 1, "handle_key consumes a registered hotkey"]
assert_eq of [hk_fired[0], 2, "handle_key fired the hotkey callback"]
unregister_hotkey of "ctrl+s"

# keyup is not a toolkit key event — it stays free for the app
ku is dispatch of [kroot, {"type": "keyup", "key": "s", "ctrl": 1, "shift": 0, "alt": 0}]
assert_eq of [ku, 0, "keyup reported unconsumed"]

# Escape pops the modal stack through dispatch
mdlg is dialog of ["mdlg", 200, 100, "T", "M", ["OK"], null]
push_modal of [mdlg, 800, 600]
assert_eq of [len of _ui.modal_stack, 1, "modal pushed"]
esc is dispatch of [kroot, {"type": "keydown", "key": "escape", "ctrl": 0, "shift": 0, "alt": 0}]
assert_eq of [len of _ui.modal_stack, 0, "escape pops modal through dispatch"]
assert_eq of [esc, 1, "escape-pops-modal reported consumed"]

# Focused text input takes keys ahead of focus navigation
ti is text_input of ["ti", 0, 0, 100, "", null]
_ui.focused_input is ti
dispatch of [kroot, {"type": "keydown", "key": "a", "ctrl": 0, "shift": 0, "alt": 0}]
assert_eq of [ti.text, "a", "focused text input receives keys through dispatch"]
_ui.focused_input is null

# ============================================================
# 13. Programmatic quit (#564)
# ============================================================

print of "--- Quit Seam Tests (#564) ---"

assert_eq of [_ui.quit_requested, 0, "quit_requested starts clear"]
request_quit of null
assert_eq of [_ui.quit_requested, 1, "request_quit sets the flag app_loop checks"]
_ui.quit_requested is 0

# ============================================================
# 14. Combobox dropdown mouse selection (#577)
# ============================================================
# NOTE: reset _ui.last_click_id between gestures (see section 8's note).

print of "--- Combobox Dropdown Selection Tests (#577) ---"

cbroot is panel of ["cbroot", 0, 0, 400, 400]
cb_changed is [0]
define cb_on_change(w) as:
    cb_changed[0] is cb_changed[0] + 1

cbx is combobox of ["cbx", 10, 10, 120, ["alpha", "beta", "gamma"], cb_on_change]
add_child of [cbroot, cbx]
_layout of [cbroot, 0, 0]

# Click the closed box — opens the dropdown
dispatch of [cbroot, {"type": "mousedown", "x": 20, "y": 20, "button": 1}]
assert_eq of [cbx.open, 1, "mousedown opens the dropdown"]

# Click item 1 ("beta"): items start at _ay + h + 2 = 36, each 24 tall,
# so item 1 spans y 60..83. This is the #577 repro — before the fix the
# dropdown closed before the hit test and selected stayed -1.
dispatch of [cbroot, {"type": "mousedown", "x": 20, "y": 62, "button": 1}]
assert_eq of [cbx.selected, 1, "dropdown item selected by mouse (#577)"]
assert_eq of [cbx.open, 0, "selecting an item closes the dropdown"]
assert_eq of [cb_changed[0], 1, "on_change fired once for the selection"]

# Item 0 is reachable too — selection follows the click's own y, not a
# stale hover_index (no mousemove precedes these clicks).
_ui.last_click_id is ""
dispatch of [cbroot, {"type": "mousedown", "x": 20, "y": 20, "button": 1}]
assert_eq of [cbx.open, 1, "dropdown reopens"]
dispatch of [cbroot, {"type": "mousedown", "x": 20, "y": 40, "button": 1}]
assert_eq of [cbx.selected, 0, "item 0 selected by its own click position"]

# A click OUTSIDE an open dropdown still closes it and does not select
_ui.last_click_id is ""
dispatch of [cbroot, {"type": "mousedown", "x": 20, "y": 20, "button": 1}]
assert_eq of [cbx.open, 1, "dropdown reopens for the outside-click case"]
dispatch of [cbroot, {"type": "mousedown", "x": 300, "y": 300, "button": 1}]
assert_eq of [cbx.open, 0, "click outside closes the dropdown"]
assert_eq of [cbx.selected, 0, "click outside leaves selection untouched"]
assert_eq of [cb_changed[0], 2, "click outside fired no extra on_change"]

# A second combobox must not be closed-then-missed either: clicking one
# closes the OTHER, and still selects in the one clicked.
cby is combobox of ["cby", 200, 10, 120, ["x", "y"], null]
add_child of [cbroot, cby]
_layout of [cbroot, 0, 0]
_ui.last_click_id is ""
dispatch of [cbroot, {"type": "mousedown", "x": 20, "y": 20, "button": 1}]
assert_eq of [cbx.open, 1, "first combobox open"]
_ui.last_click_id is ""
dispatch of [cbroot, {"type": "mousedown", "x": 210, "y": 20, "button": 1}]
assert_eq of [cbx.open, 0, "clicking a sibling closes the first dropdown"]
assert_eq of [cby.open, 1, "the clicked sibling opens"]

# ============================================================
# 15. label carries w/h (#561)
# ============================================================

print of "--- Label Metrics Tests (#561) ---"

# Stub metrics: text_width = len*6*scale, text_height = 7*scale.
lb is label of ["lb", 0, 0, "BPM"]
assert_eq of [lb.w, 36, "label w measured from its text (3 chars * 6 * 2)"]
assert_eq of [lb.h, 14, "label h measured from its scale (7 * 2)"]

# The #561 repro: a label in a toolbar crashed _layout_toolbar reading
# child.h. Survival + vertical centering is the assertion.
lroot is panel of ["lroot", 0, 0, 800, 600]
ltb is toolbar of ["ltb", 0, 0, 800]
add_child of [ltb, label of ["cap", 0, 0, "BPM"]]
add_child of [lroot, ltb]
_layout of [lroot, 0, 0]
assert_eq of [ltb.children[0].y, 13, "label vertically centered in toolbar"]

# A label's text changes at runtime — layout must remeasure, or a time
# display's box goes stale the first time it restamps.
tl is ltb.children[0]
tl.text is "120.00 BPM  00:01:23"
_layout of [lroot, 0, 0]
assert_eq of [tl.w, 240, "label remeasured after its text changed"]

# hbox lays labels out against their measured width
lhb is hbox of ["lhb", 0, 0, 400, 40]
add_child of [lhb, label of ["la", 0, 0, "one"]]
add_child of [lhb, label of ["lbb", 0, 0, "two"]]
add_child of [lroot, lhb]
_layout of [lroot, 0, 0]
assert_eq of [lhb.children[0].x, 0, "first label at box origin"]
assert_eq of [lhb.children[1].x, 36, "second label advanced by the first's width"]

# ============================================================
# 16. grid cell ownership + row-label gutter (#572)
# ============================================================

print of "--- Grid Ownership Tests (#572) ---"

groot is panel of ["groot", 0, 0, 400, 400]
seen_val is [-1]
define g_on_cell(w, r, c) as:
    seen_val[0] is w.cells[r][c]

gd is grid of ["gd", 80, 10, 4, 4, 20, 20, g_on_cell]
add_child of [groot, gd]
_layout of [groot, 0, 0]

# Default: the widget owns the pattern and flips before reporting
assert_eq of [gd.owns_cells, 1, "grid owns its cells by default"]
dispatch of [groot, {"type": "mousedown", "x": 90, "y": 20, "button": 1}]
assert_eq of [gd.cells[0][0], 1, "owning grid flips the cell itself"]
assert_eq of [seen_val[0], 1, "on_cell sees the flipped value"]

# owns_cells = 0: input reports the hit and leaves cells alone, so an app
# whose model is the source of truth decides (the #572 repro).
gd.owns_cells is 0
gd.cells[1][1] is 0
_ui.last_click_id is ""
dispatch of [groot, {"type": "mousedown", "x": 110, "y": 40, "button": 1}]
assert_eq of [gd.cells[1][1], 0, "non-owning grid leaves the cell untouched"]
assert_eq of [seen_val[0], 0, "on_cell still reports the hit"]

# Keyboard must follow the same ownership rule as the mouse
gd.hover_row is 2
gd.hover_col is 2
gd.cells[2][2] is 0
_ui.focused_widget is gd
_handle_focus_key of [groot, {"key": "space", "shift": 0, "ctrl": 0, "alt": 0}]
assert_eq of [gd.cells[2][2], 0, "non-owning grid: keyboard does not flip either"]
gd.owns_cells is 1
_handle_focus_key of [groot, {"key": "space", "shift": 0, "ctrl": 0, "alt": 0}]
assert_eq of [gd.cells[2][2], 1, "owning grid: keyboard flips"]
_ui.focused_widget is null

# The row-label gutter is configurable rather than a hardcoded -60/scale-1
assert_eq of [gd.row_label_w, 60, "row-label gutter defaults to the historical 60"]
assert_eq of [gd.row_label_scale, 1, "row-label scale defaults to the historical 1"]

# ============================================================
# 17. Piano key release (#570)
# ============================================================

print of "--- Piano Release Tests (#570) ---"

proot is panel of ["proot", 0, 0, 400, 400]
pnotes is []
define p_on_note(w, n, on) as:
    append of [pnotes, [n, on]]

pk is piano_keyboard of ["pk", 0, 100, 2, p_on_note]
add_child of [proot, pk]
_layout of [proot, 0, 0]

# Press and release on the key: note-on then note-off
dispatch of [proot, {"type": "mousedown", "x": 5, "y": 110, "button": 1}]
assert_eq of [pk.pressed_note, 0, "mousedown presses the key"]
dispatch of [proot, {"type": "mouseup", "x": 5, "y": 110, "button": 1}]
assert_eq of [pk.pressed_note, 0 - 1, "mouseup releases the key"]
assert_eq of [len of pnotes, 2, "press+release produced two events"]
assert_eq of [pnotes[1][1], 0, "release fired note-off"]

# The #570 residual: press a key, then release with the pointer OFF the
# widget entirely. The note-off used to be a dispatch special case that
# only ran when mouseup hit-tested back to the same widget, so the note
# stuck on forever.
pnotes is []
_ui.last_click_id is ""
dispatch of [proot, {"type": "mousedown", "x": 5, "y": 110, "button": 1}]
assert_eq of [pk.pressed_note, 0, "key pressed before dragging off"]
dispatch of [proot, {"type": "mouseup", "x": 350, "y": 350, "button": 1}]
assert_eq of [pk.pressed_note, 0 - 1, "key released even though mouseup missed it"]
assert_eq of [pnotes[1][1], 0, "note-off fired on release-off-widget (#570)"]

# Releasing over ANOTHER widget must also release the key — that path
# returned early before reaching the release walk.
pbtn is button of ["pbtn", 200, 200, 80, 30, "x", null]
add_child of [proot, pbtn]
_layout of [proot, 0, 0]
pnotes is []
_ui.last_click_id is ""
dispatch of [proot, {"type": "mousedown", "x": 5, "y": 110, "button": 1}]
dispatch of [proot, {"type": "mouseup", "x": 210, "y": 210, "button": 1}]
assert_eq of [pk.pressed_note, 0 - 1, "key released when mouseup landed on a button"]
assert_eq of [pnotes[1][1], 0, "note-off fired when releasing over a button"]

# ============================================================
# 18. Hover feedback beyond buttons (#594)
# ============================================================
# Renders are verified by capturing what the renderer emits: the shade is
# the only gfx_rrect carrying an alpha (9th) argument, so recording those
# tells us whether a widget drew hover feedback at all. dispatch already
# set .hover for checkbox/toggle; only their renderers ignored it.

print of "--- Hover Shade Tests (#594) ---"

shade_alphas is []
define gfx_rrect(x, y, w, h, r, cr, cg, cb, ca) as:
    if ca != null:
        append of [shade_alphas, ca]
    return null

# checkbox: not hovered -> no shade
cbx2 is checkbox of ["cbx2", 0, 0, "Snap", 0, null]
cbx2.hover is 0
shade_alphas is []
_render_checkbox of [cbx2, 0, 0]
assert_eq of [len of shade_alphas, 0, "unhovered checkbox draws no shade"]

# checkbox: hovered -> theme hover_shade alpha
cbx2.hover is 1
shade_alphas is []
_render_checkbox of [cbx2, 0, 0]
assert_eq of [len of shade_alphas, 1, "hovered checkbox draws a shade (#594)"]
assert_eq of [shade_alphas[0], 22, "checkbox shade uses theme hover_shade alpha"]

# checkbox: disabled and hovered -> still no shade
cbx2.enabled is 0
shade_alphas is []
_render_checkbox of [cbx2, 0, 0]
assert_eq of [len of shade_alphas, 0, "disabled checkbox draws no shade even when hovered"]
cbx2.enabled is 1

# toggle: same treatment
tg2 is toggle of ["tg2", 0, 0, 0, null]
tg2.hover is 1
shade_alphas is []
_render_toggle of [tg2, 0, 0]
assert_eq of [len of shade_alphas, 1, "hovered toggle draws a shade (#594)"]
assert_eq of [shade_alphas[0], 22, "toggle shade uses theme hover_shade alpha"]

tg2.hover is 0
shade_alphas is []
_render_toggle of [tg2, 0, 0]
assert_eq of [len of shade_alphas, 0, "unhovered toggle draws no shade"]

# A custom-colored button prefers the pressed shade over the hover one,
# and a theme-colored button still swaps bg instead of shading.
btn2 is button of ["btn2", 0, 0, 60, 24, "Rec", null]
btn2.bg is [200, 60, 60]
btn2.hover is 1
btn2.pressed is 1
shade_alphas is []
_render_button of [btn2, 0, 0]
assert_eq of [shade_alphas[0], 70, "pressed custom button uses pressed_shade alpha"]

btn3 is button of ["btn3", 0, 0, 60, 24, "Play", null]
btn3.hover is 1
shade_alphas is []
_render_button of [btn3, 0, 0]
assert_eq of [len of shade_alphas, 0, "theme-colored button swaps bg rather than shading"]

# ============================================================
# Summary
# ============================================================

test_summary of null
