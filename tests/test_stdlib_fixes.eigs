# Regression tests for stdlib fixes:
# - math.eigs dot: bounds-safe on mismatched lengths
# - test.eigs assert_near: rejects non-numeric operands
# - template.eigs render: no template-injection from variable values
# - text_builder.eigs: shared buffered text assembly
# - int_vector.eigs: fixed-size integer vectors over buffers
# - list.eigs take/drop: first-n / rest-of-n list slicing

load_file of "lib/math.eigs"
load_file of "lib/test.eigs"
load_file of "lib/template.eigs"
load_file of "lib/text_builder.eigs"
load_file of "lib/int_vector.eigs"
load_file of "lib/list.eigs"

# --- math.dot bounds ---
assert of [(dot of [[1, 2, 3], [4, 5, 6]]) == 32, "SF1 dot normal"]
# Mismatched lengths must not crash; iterate over the shorter list.
assert of [(dot of [[1, 2, 3], [4, 5]]) == 14, "SF2 dot shorter b"]
assert of [(dot of [[1, 2], [4, 5, 6]]) == 14, "SF3 dot shorter a"]
assert of [(dot of [[], [1, 2, 3]]) == 0, "SF4 dot empty a"]
assert of [(dot of [[1, 2, 3], []]) == 0, "SF5 dot empty b"]

# --- test.assert_near type guard ---
# These must not silently pass on non-numeric input. Use the library's
# internal counters to detect: a non-numeric call must bump _test_fail.
before_pass is _test_pass
before_fail is _test_fail
assert_near of [1.0, 1.0001, 0.01, "numeric OK"]
after_numeric_pass is _test_pass
assert of [(after_numeric_pass - before_pass) == 1, "SF6 assert_near numeric counts as pass"]

before_fail_2 is _test_fail
assert_near of ["not a number", 1.0, 0.01, "bad operand"]
after_bad_fail is _test_fail
assert of [(after_bad_fail - before_fail_2) == 1, "SF7 assert_near non-numeric counts as fail"]

# Reset counters so [41b] doesn't report a spurious failure from
# the deliberately-wrong assert_near above.
_test_pass is 0
_test_fail is 0
_test_errors is []

# --- template.render injection ---
# A variable's value containing {{other}} must be emitted verbatim,
# not re-substituted in a second pass.
vars is [["user", "{{admin}}"], ["admin", "pwned"]]
rendered is render of ["Hello {{user}}!", vars]
assert of [rendered == "Hello {{admin}}!", "SF8 template no-reinterpretation of values"]

# Normal substitution still works.
vars2 is [["name", "World"], ["n", "42"]]
r2 is render of ["Hi {{name}}, count={{n}}.", vars2]
assert of [r2 == "Hi World, count=42.", "SF9 template normal substitution"]

# Unknown placeholder is left as-is.
r3 is render of ["{{missing}} remains", []]
assert of [r3 == "{{missing}} remains", "SF10 template unknown placeholder"]

# Unterminated placeholder is emitted verbatim.
r4 is render of ["prefix {{forever", [["forever", "nope"]]]
assert of [r4 == "prefix {{forever", "SF11 template unterminated placeholder"]

builder is text_builder_new of null
assert of [(text_builder_part_count of builder) == 0, "SF12 text_builder starts empty"]
assert of [(type of builder) == "text_builder", "SF13 text_builder native type"]
assert of [(len of builder) == 0, "SF14 text_builder starts empty length"]
text_builder_append of [builder, "p cnf "]
text_builder_append of [builder, 3]
text_builder_extend of [builder, [" ", 2]]
assert of [(text_builder_part_count of builder) == 4, "SF15 text_builder part count"]
line_prefix is text_builder_to_string of builder
assert of [line_prefix == "p cnf 3 2", "SF16 text_builder append and extend"]
assert of [(len of builder) == (len of line_prefix), "SF17 text_builder native length"]
text_builder_append_line of [builder, ""]
text_builder_append_line of [builder, "1 -2 0"]
text_builder_append_line of [builder, "3 0"]
dimacs_text is text_builder_to_string of builder
assert of [dimacs_text == "p cnf 3 2\n1 -2 0\n3 0\n", "SF18 text_builder line assembly"]
text_builder_clear of builder
assert of [(text_builder_part_count of builder) == 0, "SF19 text_builder clear count"]
assert of [(text_builder_to_string of builder) == "", "SF20 text_builder clear render"]
text_builder_append_line of [builder, "reuse"]
assert of [(text_builder_to_string of builder) == "reuse\n", "SF21 text_builder reuse"]
assert of [(str of builder) == "reuse\n", "SF22 text_builder str renders text"]

vec is int_vector_new of 4
assert of [(type of vec) == "buffer", "SF23 int_vector_new returns buffer"]
assert of [(len of vec) == 4, "SF24 int_vector_new length"]
assert of [vec[0] == 0, "SF25 int_vector_new zero-filled"]
vec[2] is 9
assert of [vec[2] == 9, "SF26 int_vector direct assignment"]

filled is int_vector_filled of [3, -1.7]
assert of [(len of filled) == 3, "SF27 int_vector_filled length"]
assert of [filled[0] == -2, "SF28 int_vector_filled floors negative"]
assert of [filled[2] == -2, "SF29 int_vector_filled fills all"]

from_list is int_vector_from_list of [1.2, 2.9, -3.1]
assert of [(type of from_list) == "buffer", "SF30 int_vector_from_list returns buffer"]
assert of [from_list[0] == 1, "SF31 int_vector_from_list floors positive"]
assert of [from_list[2] == -4, "SF32 int_vector_from_list floors negative"]

int_vector_set of [from_list, 1, 8.8]
assert of [(int_vector_get of [from_list, 1]) == 8, "SF33 int_vector get/set floor"]

clone is int_vector_clone of from_list
from_list[1] is 99
assert of [clone[1] == 8, "SF34 int_vector_clone independent copy"]

dst is int_vector_filled of [5, 0]
int_vector_copy of [clone, 0, dst, 1, 3]
assert of [dst[0] == 0, "SF35 int_vector_copy leaves prefix"]
assert of [dst[1] == 1, "SF36 int_vector_copy first copied"]
assert of [dst[3] == -4, "SF37 int_vector_copy last copied"]
as_list is int_vector_to_list of dst
as_list_ok is (len of as_list) == 5 and as_list[0] == 0 and as_list[1] == 1 and as_list[2] == 8 and as_list[3] == -4 and as_list[4] == 0
assert of [as_list_ok, "SF38 int_vector_to_list"]
assert of [(int_vector_len of dst) == 5, "SF39 int_vector_len"]
int_vector_fill of [dst, 6.6]
assert of [dst[4] == 6, "SF40 int_vector_fill"]

# --- list.take ---
assert of [(take of [[1, 2, 3, 4, 5], 2]) == [1, 2], "SF41 take normal"]
assert of [(take of [[1, 2, 3], 0]) == [], "SF42 take zero"]
assert of [(take of [[1, 2], 5]) == [1, 2], "SF43 take exceeds length"]
assert of [(take of [[], 3]) == [], "SF44 take empty list"]

# --- list.drop ---
assert of [(drop of [[1, 2, 3, 4, 5], 2]) == [3, 4, 5], "SF45 drop normal"]
assert of [(drop of [[1, 2, 3], 0]) == [1, 2, 3], "SF46 drop zero"]
assert of [(drop of [[1, 2], 5]) == [], "SF47 drop exceeds length"]
assert of [(drop of [[], 3]) == [], "SF48 drop empty list"]

# --- list.any / list.all ---
assert of [(any of [[0, 0, 3, 0], (x) => x > 0]) == 1, "SF49 any matches mid"]
assert of [(any of [[5, 0, 0], (x) => x > 0]) == 1, "SF50 any short-circuits on first match"]
assert of [(any of [[0, 0, 0], (x) => x > 0]) == 0, "SF51 any none match"]
assert of [(any of [[], (x) => x > 0]) == 0, "SF52 any empty list is false"]
assert of [(all of [[1, 2, 3], (x) => x > 0]) == 1, "SF53 all match"]
assert of [(all of [[1, -1, 3], (x) => x > 0]) == 0, "SF54 all short-circuits on first fail"]
assert of [(all of [[], (x) => x > 0]) == 1, "SF55 all empty list is vacuously true"]

# --- list.find_index ---
assert of [(find_index of [[10, 20, 30, 40], (x) => x > 25]) == 2, "SF56 find_index middle"]
assert of [(find_index of [[5, 1, 2], (x) => x > 4]) == 0, "SF57 find_index at start"]
assert of [(find_index of [[1, 2, 9], (x) => x > 4]) == 2, "SF58 find_index at end"]
assert of [(find_index of [[1, 2, 3], (x) => x > 100]) == -1, "SF59 find_index no match"]
assert of [(find_index of [[], (x) => 1]) == -1, "SF60 find_index empty list"]

# --- list.partition ---
assert of [(partition of [[1, 2, 3, 4, 5], (x) => x % 2 == 0]) == [[2, 4], [1, 3, 5]], "SF61 partition mixed"]
assert of [(partition of [[1, 1, 1], (x) => x > 0]) == [[1, 1, 1], []], "SF62 partition all pass"]
assert of [(partition of [[1, 1, 1], (x) => x > 5]) == [[], [1, 1, 1]], "SF63 partition all fail"]
assert of [(partition of [[], (x) => 1]) == [[], []], "SF64 partition empty"]

# --- list.group_by ---
gb is group_by of [[1, 2, 3, 4], (x) => x % 2]
assert of [(gb["0"]) == [2, 4] and (gb["1"]) == [1, 3], "SF65 group_by scalar keys (stringified)"]
gb_one is group_by of [[1, 2, 3], (x) => 0]
assert of [(gb_one["0"]) == [1, 2, 3], "SF66 group_by all-same-key one bucket"]
assert of [(len of (keys of (group_by of [[], (x) => x]))) == 0, "SF67 group_by empty list -> empty dict"]
gitems is [{"tag": "a", "v": 1}, {"tag": "b", "v": 2}, {"tag": "a", "v": 3}]
gb_d is group_by of [gitems, (it) => it["tag"]]
assert of [(len of gb_d["a"]) == 2 and (len of gb_d["b"]) == 1, "SF68 group_by dict key (single + multi buckets)"]
assert of [(gb_d["a"][0])["v"] == 1 and (gb_d["a"][1])["v"] == 3, "SF69 group_by preserves insertion order"]

# --- list.deep_flatten ---
assert of [(deep_flatten of [[1, [2, 3]], [4]]) == [1, 2, 3, 4], "SF70 deep_flatten nested"]
assert of [(deep_flatten of [1, [2, [3, [4]]]]) == [1, 2, 3, 4], "SF71 deep_flatten deeply nested"]
assert of [(deep_flatten of [1, 2, 3]) == [1, 2, 3], "SF72 deep_flatten already flat"]
assert of [(deep_flatten of [1, [2, 3], 4]) == [1, 2, 3, 4], "SF73 deep_flatten mixed level"]
assert of [(deep_flatten of [[1, 2], [3]]) == [1, 2, 3], "SF74 deep_flatten single level"]
assert of [(deep_flatten of []) == [], "SF75 deep_flatten empty"]

# --- list.count_of / list.frequencies ---
assert of [(count_of of [[1, 2, 2, 3, 2, 1], 2]) == 3, "SF76 count_of multiple"]
assert of [(count_of of [["a", "b", "a"], "a"]) == 2, "SF77 count_of strings"]
assert of [(count_of of [[1, 2, 3], 9]) == 0, "SF78 count_of absent"]
assert of [(count_of of [[], 5]) == 0, "SF79 count_of empty"]
assert of [(count_of of [[7], 7]) == 1, "SF80 count_of single element"]
fr is frequencies of [1, 2, 2, 3, 2, 1]
assert of [fr["1"] == 2 and fr["2"] == 3 and fr["3"] == 1, "SF81 frequencies distribution"]
assert of [(has_key of [fr, "9"]) == 0, "SF82 frequencies omits absent values"]
assert of [(len of (keys of (frequencies of []))) == 0, "SF83 frequencies empty -> empty dict"]
fr_mixed is frequencies of ["a", 1, "a", 1, 1]
assert of [fr_mixed["a"] == 2 and fr_mixed["1"] == 3, "SF84 frequencies mixed types"]

# --- math.argmax / math.argmin ---
assert of [(argmax of [3, 1, 4, 1, 5, 9, 2, 6]) == 5, "SF85 argmax middle"]
assert of [(argmax of [9, 1, 2]) == 0, "SF86 argmax at start"]
assert of [(argmax of [1, 2, 9]) == 2, "SF87 argmax at end"]
assert of [(argmax of [5, 5, 5]) == 0, "SF88 argmax ties keep first index"]
assert of [(argmax of ([7])) == 0, "SF89 argmax single element"]
assert of [(argmax of []) == -1, "SF90 argmax empty -> -1"]
assert of [(argmin of [3, 1, 4, 1, 5, 9, 2, 6]) == 1, "SF91 argmin first min on tie"]
assert of [(argmin of [-2, -5, -1]) == 1, "SF92 argmin negatives"]
assert of [(argmin of []) == -1, "SF93 argmin empty -> -1"]

# --- math.log2 / math.log10 ---
assert of [(log2 of 8) == 3, "SF94 log2 of 8"]
assert of [(log2 of 1) == 0, "SF95 log2 of 1"]
assert of [(log2 of 0.5) == -1, "SF96 log2 of one half"]
assert of [(log10 of 1) == 0, "SF97 log10 of 1"]
assert of [(abs of ((log10 of 1000) - 3)) < 0.0000001, "SF98 log10 of 1000"]
assert of [(pow of [2, log2 of 8]) == 8, "SF99 log2/pow round trip"]
assert of [(abs of ((pow of [10, log10 of 1000]) - 1000)) < 0.0000001, "SF100 log10/pow round trip"]
# x <= 0 inherits the log builtin's input floor at 1e-10 — no error.
assert of [(log10 of 0) == -10, "SF101 log10 floored at 0"]
assert of [(abs of ((log2 of -1) + 33.219280948873624)) < 0.0000001, "SF102 log2 floored below 0"]
# Element-wise, like the log they wrap: log of [8, 4] works, so these
# must too. Built on `divide`, not `/`, which is scalar-only.
lg2 is log2 of [8, 4, 1]
assert of [(len of lg2) == 3, "SF103 log2 over a list returns a list"]
assert of [lg2[0] == 3, "SF104 log2 element-wise [0]"]
assert of [lg2[1] == 2, "SF105 log2 element-wise [1]"]
assert of [lg2[2] == 0, "SF106 log2 element-wise [2]"]
lg10 is log10 of [1, 100]
assert of [lg10[0] == 0, "SF107 log10 element-wise [0]"]
assert of [(abs of (lg10[1] - 2)) < 0.0000001, "SF108 log10 element-wise [1]"]
# The scalar path is unchanged by divide — same value as the log it wraps.
assert of [(log2 of 8) == ((log of 8) / 0.6931471805599453), "SF109 log2 scalar unchanged by divide"]
assert of [(log10 of 1000) == ((log of 1000) / 2.302585092994046), "SF110 log10 scalar unchanged by divide"]

print of "All stdlib-fix tests passed"
