# EigenStore header-validation / corruption error paths.
#
# Branch coverage put ext_store.c at ~60% branches-taken: store_open's
# header validator (store_read_header) rejects malformed database files
# field by field, but nothing in the suite fed it a malformed file, so
# every rejection branch was untaken. Each case below writes a file that
# is valid except for one corrupted header field (or an oversized
# record), opens it, and asserts the catchable runtime error fires.
#
# The store format (src/ext_store_internal.h): 64-byte header then
# 4096-byte pages. Header layout: magic "EIGS" (0..3), version=1 LE
# (4..7), page_size=4096 LE (8..11), page_count LE (12..15),
# free_page LE (16..19). All header-validation failures surface to
# script as "invalid database file"; each case targets a different
# internal branch (commented).

# A 64-byte header, valid except for the page_count field (caller sets it).
# page_size low byte is 0 and hdr[9]=16 -> 0x1000 = 4096.
define base_hdr(page_count) as:
    b is []
    for x in [69, 73, 71, 83, 1, 0, 0, 0, 0, 16, 0, 0]:
        append of [b, x]
    append of [b, page_count]
    loop while (len of b) < 64:
        append of [b, 0]
    return b

# ---- corrupt magic (store_read_header magic check) ----
zeros is []
loop while (len of zeros) < 64:
    append of [zeros, 0]
write_bytes of ["/tmp/eigs_corrupt_magic.db", zeros, 0]
cm is 0
mm is ""
try:
    d is store_open of "/tmp/eigs_corrupt_magic.db"
catch e:
    cm is 1
    mm is e
assert of [cm == 1, "SC01 corrupt magic rejected"]
assert of [(contains of [mm.message, "invalid database file"]) == 1, "SC01 message"]

# ---- corrupt version (version != 1) ----
hv is base_hdr of 1
hv[4] is 9
write_bytes of ["/tmp/eigs_corrupt_ver.db", hv, 0]
cv is 0
mv is ""
try:
    d is store_open of "/tmp/eigs_corrupt_ver.db"
catch e:
    cv is 1
    mv is e
assert of [cv == 1, "SC02 corrupt version rejected"]
assert of [(contains of [mv.message, "invalid database file"]) == 1, "SC02 message"]

# ---- corrupt page_size (4097 != 4096) ----
hp is base_hdr of 1
hp[8] is 1
write_bytes of ["/tmp/eigs_corrupt_ps.db", hp, 0]
cp is 0
mp is ""
try:
    d is store_open of "/tmp/eigs_corrupt_ps.db"
catch e:
    cp is 1
    mp is e
assert of [cp == 1, "SC03 corrupt page_size rejected"]
assert of [(contains of [mp.message, "invalid database file"]) == 1, "SC03 message"]

# ---- not page-aligned (header + 10 stray bytes) ----
ha is base_hdr of 1
write_bytes of ["/tmp/eigs_corrupt_align.db", ha, 0]
stray is []
loop while (len of stray) < 10:
    append of [stray, 0]
write_bytes of ["/tmp/eigs_corrupt_align.db", stray, 1]
ca is 0
ma is ""
try:
    d is store_open of "/tmp/eigs_corrupt_align.db"
catch e:
    ca is 1
    ma is e
assert of [ca == 1, "SC04 non-page-aligned file rejected"]
assert of [(contains of [ma.message, "invalid database file"]) == 1, "SC04 message"]

# ---- page_count mismatch (header claims 5, file has 1 page) ----
hpc is base_hdr of 5
write_bytes of ["/tmp/eigs_corrupt_pc.db", hpc, 0]
onepage is []
loop while (len of onepage) < 4096:
    append of [onepage, 0]
write_bytes of ["/tmp/eigs_corrupt_pc.db", onepage, 1]
cpc is 0
mpc is ""
try:
    d is store_open of "/tmp/eigs_corrupt_pc.db"
catch e:
    cpc is 1
    mpc is e
assert of [cpc == 1, "SC05 page_count mismatch rejected"]
assert of [(contains of [mpc.message, "invalid database file"]) == 1, "SC05 message"]

# ---- store_put: record larger than a page ----
db is store_open of "/tmp/eigs_corrupt_put.db"
big is "x"
loop while (len of big) < 8000:
    big is big + big
cput is 0
mput is ""
try:
    k is store_put of [db, "c", {"v": big}]
catch e:
    cput is 1
    mput is e
assert of [cput == 1, "SC06 oversized record rejected"]
assert of [(contains of [mput.message, "exceeds page size"]) == 1, "SC06 message"]
store_close of db

print of "All store_corruption tests passed"
