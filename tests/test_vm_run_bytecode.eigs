# vm_run_bytecode — the self-hosting bootstrap bridge. Assemble a chunk from
# EigenScript values (code bytes + constant pool) and run it on the C VM.
# Opcodes/operands are exactly what compile_ast emits (16-bit operands are
# little-endian); this is what an EigenScript-written compiler will produce.

load_file of "lib/test.eigs"

# Opcode numbers (src/vm.h enum order)
CONST is 0
ADD is 4
GT is 20
GET_NAME is 25
JUMP_IF_FALSE is 31
CALL is 39
RETURN is 40

# 2 + 3 -> 5
assert_eq of [vm_run_bytecode of [[CONST,0,0, CONST,1,0, ADD, RETURN], [2, 3]], 5, "arith add"]

# string concat "a" + "b" -> "ab"
assert_eq of [vm_run_bytecode of [[CONST,0,0, CONST,1,0, ADD, RETURN], ["a", "b"]], "ab", "string concat via ADD"]

# comparison 10 > 3 -> 1
assert_eq of [vm_run_bytecode of [[CONST,0,0, CONST,1,0, GT, RETURN], [10, 3]], 1, "comparison GT"]

# builtin call: len of "hello" -> 5  (GET_NAME resolves "len" in the global env)
assert_eq of [vm_run_bytecode of [[GET_NAME,0,0, CONST,1,0, CALL,1,0, RETURN], ["len", "hello"]], 5, "builtin call via GET_NAME+CALL"]

# control flow: max(a, b) via JUMP_IF_FALSE (relative forward offset)
#   CONST a; CONST b; GT; JUMP_IF_FALSE +4; CONST a; RETURN; CONST b; RETURN
maxcode is [CONST,0,0, CONST,1,0, GT, JUMP_IF_FALSE,4,0, CONST,0,0, RETURN, CONST,1,0, RETURN]
assert_eq of [vm_run_bytecode of [maxcode, [10, 3]], 10, "max(10,3) fall-through branch"]
assert_eq of [vm_run_bytecode of [maxcode, [3, 10]], 10, "max(3,10) jump-taken branch"]
assert_eq of [vm_run_bytecode of [maxcode, [7, 2]], 7, "max(7,2)"]

# bad args degrade to null, not a crash
assert_eq of [vm_run_bytecode of [42, []], null, "non-list code -> null"]
assert_eq of [vm_run_bytecode of 5, null, "non-list arg -> null"]

# nested function chunk: define double(x) = x + x; double of 21 -> 42
CLOSURE is 38
SET_NAME_LOCAL is 27
GET_LOCAL is 23
RETURN_NULL is 41
POP is 35
# function body: GET_LOCAL 0; GET_LOCAL 0; ADD; RETURN; RETURN_NULL
dbl_desc is [[GET_LOCAL,0,0, GET_LOCAL,0,0, ADD, RETURN, RETURN_NULL], [], [], 1, "double", ["x"]]
# module: CLOSURE 0; SET_NAME_LOCAL 0("double"); POP; GET_NAME 0; CONST 1(21); CALL 1; RETURN
mod_code is [CLOSURE,0,0, SET_NAME_LOCAL,0,0, POP, GET_NAME,0,0, CONST,1,0, CALL,1,0, RETURN]
assert_eq of [vm_run_bytecode of [mod_code, ["double", 21], [dbl_desc], 0, "<module>", []], 42, "nested function call"]

# record_history toggles per-assignment history recording (for prev / at queries
# in self-hosted programs) and returns the previous setting.
record_history of 0
assert_eq of [record_history of 1, 0, "record_history: was off -> returns 0"]
assert_eq of [record_history of 1, 1, "record_history: now on -> returns 1"]
record_history of 0

# A non-numeric flag raises rather than silently coercing to disable (#255):
# silently turning history OFF on a bad arg made prev/at return null with no
# error, hard to trace back to this call. Strict, like the rest of the runtime.
rh_null_caught is 0
try:
    record_history of null
catch e:
    rh_null_caught is 1
assert of [rh_null_caught == 1, "record_history: null flag raises (no silent disable)"]
rh_str_caught is 0
try:
    record_history of "yes"
catch e:
    rh_str_caught is 1
assert of [rh_str_caught == 1, "record_history: string flag raises (no silent disable)"]
record_history of 0

# sandbox_run: safe code runs and returns {ok, result}. The arg is
# [descriptor, max_iter] where descriptor is [code, constants].
safe_desc is [[CONST,0,0, CONST,1,0, ADD, RETURN], [2, 3]]
sr_safe is sandbox_run of [safe_desc, 100000]
assert_eq of [sr_safe["ok"], 1, "sandbox: safe code ok"]
assert_eq of [sr_safe["result"], 5, "sandbox: safe result"]

# sandbox_run: a dangerous builtin (write_text) is shadowed -> blocked, ok=0,
# and no file is written.
remove_file of "/tmp/eigs_sandbox_breach"
block_desc is [[GET_NAME,0,0, CONST,1,0, CALL,1,0, RETURN], ["write_text", "/tmp/eigs_sandbox_breach"]]
sr_block is sandbox_run of [block_desc, 100000]
assert_eq of [sr_block["ok"], 0, "sandbox: dangerous builtin blocked"]
assert_eq of [file_exists of "/tmp/eigs_sandbox_breach", 0, "sandbox: nothing written"]

# sandbox_run: BLOCKING builtins are denied too. The g_sandbox_loop_max bound
# counts loop back-edges, not time inside one builtin, so a single blocking call
# (usleep/raw_key/recv) would hang the host indefinitely. These must be shadowed
# -> {ok:0}, NOT executed. If any regresses, this run HANGS (the suite timeout
# is the backstop): usleep would sleep 30s, raw_key would read() stdin, recv
# would wait on a channel condvar forever.
usleep_desc is [[GET_NAME,0,0, CONST,1,0, CALL,1,0, RETURN], ["usleep", 30000000]]
assert_eq of [(sandbox_run of [usleep_desc, 100000])["ok"], 0, "sandbox: usleep blocked (no 30s hang)"]
rawkey_desc is [[GET_NAME,0,0, CALL,0,0, RETURN], ["raw_key"]]
assert_eq of [(sandbox_run of [rawkey_desc, 100000])["ok"], 0, "sandbox: raw_key blocked (no stdin read)"]
recv_desc is [[GET_NAME,0,0, CONST,1,0, CALL,1,0, RETURN], ["recv", 0]]
assert_eq of [(sandbox_run of [recv_desc, 100000])["ok"], 0, "sandbox: recv blocked (no channel-wait hang)"]
send_desc is [[GET_NAME,0,0, CONST,1,0, CALL,1,0, RETURN], ["send", 0]]
assert_eq of [(sandbox_run of [send_desc, 100000])["ok"], 0, "sandbox: send blocked"]

# sandbox_run: a runaway loop is bounded by the iteration cap (returns, no hang).
# NUM_ONE; JUMP_IF_FALSE +6; LOOP_CAP_CHECK +3; JUMP_BACK 10; RETURN_NULL
loopcode is [3, 31,6,0, 63,3,0, 30,10,0, 41]
sr_loop is sandbox_run of [[loopcode, []], 1000]
assert_eq of [sr_loop["ok"], 1, "sandbox: runaway loop bounded (returned)"]

# --- bytecode verifier: out-of-range operands are rejected, not run ---
# Untrusted/hand-assembled descriptors must never reach the VM with an
# operand that drives an out-of-bounds read. The verifier rejects the chunk
# (vm_run_bytecode -> null; sandbox_run -> {ok:0}) instead of segfaulting.

# constant index past the pool (0xFFFF) — was an OOB read of constants[]
assert_eq of [vm_run_bytecode of [[CONST,255,255, RETURN], [42]], null, "verify: OOB const index rejected"]
# forward jump target past the end of code
assert_eq of [vm_run_bytecode of [[CONST,0,0, JUMP_IF_FALSE,255,255, RETURN], [1]], null, "verify: OOB jump target rejected"]
# CLOSURE referencing a function index with no functions present
assert_eq of [vm_run_bytecode of [[CLOSURE,0,0, RETURN], []], null, "verify: OOB function index rejected"]
# truncated operand (opcode with no room for its 2 operand bytes)
assert_eq of [vm_run_bytecode of [[CONST], [42]], null, "verify: truncated operand rejected"]
# unknown opcode byte
assert_eq of [vm_run_bytecode of [[254, RETURN], []], null, "verify: unknown opcode rejected"]
# same, through the sandbox: a bad descriptor returns ok=0, no crash
sr_bad is sandbox_run of [[[CONST,255,255, RETURN], [42]], 1000]
assert_eq of [sr_bad["ok"], 0, "verify: sandbox rejects OOB const (ok=0)"]

# a name-consuming opcode (GET_NAME) whose constant index points at a NUMERIC
# constant — the interned-name pointer is NULL for non-strings, so the VM
# dereferenced NULL. The verifier now requires name operands to be strings.
DICT is 43
assert_eq of [vm_run_bytecode of [[GET_NAME,0,0, RETURN], [42]], null, "verify: name op on numeric const rejected"]
# OP_DICT with a count larger than the live stack — was an out-of-bounds stack
# read; now bounded to the pairs actually present (here none -> empty dict).
dr is vm_run_bytecode of [[DICT,255,255, RETURN], []]
assert_eq of [type of dr, "dict", "verify: OP_DICT oversized count bounded (no OOB)"]

test_summary of null
