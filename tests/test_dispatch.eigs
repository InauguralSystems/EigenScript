# test_dispatch.eigs — OP_DISPATCH key handling.
#
# Regression for boxed-VAL_NUM keys silently returning null (introduced
# by the 2026-05-22 slot-direct OP_DISPATCH refactor, which assumed keys
# are always immediate-num and dropped the slow path — exposed by DMG's
# per-instruction `dispatch of [_op_table, op, _exec_ctx]` where `op`
# comes from a fetch8 call). Also pins the float-discipline promise on
# the dispatch key.

pass_count is 0
fail_count is 0

define check(args) as:
    label is args[0]
    cond is args[1]
    if cond:
        pass_count is pass_count + 1
    else:
        fail_count is fail_count + 1
        print of ("FAIL: " + label)

define f0(x) as:
    return 10

define f1(x) as:
    return 20

define f2(x) as:
    return 30

define get_key() as:
    return 1

t is [f0, f1, f2]

# Literal key — the original happy path.
check of ["literal key 0", (dispatch of [t, 0, null]) == 10]
check of ["literal key 2", (dispatch of [t, 2, null]) == 30]

# Key from fn return — the regression.
k is get_key of null
check of ["fn-return key", (dispatch of [t, k, null]) == 20]

# Key from arithmetic — same regression shape.
k2 is 0 + 1
check of ["arithmetic key", (dispatch of [t, k2, null]) == 20]

# Key inside a function body (DMG's actual pattern).
define inner() as:
    op is get_key of null
    return dispatch of [t, op, null]
check of ["fn-body key", (inner of null) == 20]

# Integer-valued double accepted (single-number-type consistency).
check of ["int-valued double key", (dispatch of [t, 1.0, null]) == 20]

# Fractional key raises (float-index discipline extends to dispatch).
caught_frac is ""
try:
    x is dispatch of [t, 1.5, null]
catch e:
    caught_frac is e
check of ["fractional key raises", contains of [caught_frac.message, "integer"]]

# Out-of-range key still silently nulls (deliberate — sparse tables; both
# implementations agree, see builtin_dispatch).
check of ["OOB key silently null", (dispatch of [t, 99, null]) == null]
check of ["negative key silently null", (dispatch of [t, -1, null]) == null]

# ---- #353: the OP_DISPATCH fast path must raise exactly where the ----
# ---- reference builtin_dispatch raises (literal arg = opcode path) ----

# Non-list table raises (was a silent null).
caught_tbl is ""
try:
    x is dispatch of [42, 0, 7]
catch e:
    caught_tbl is e
check of ["non-list table raises", contains of [caught_tbl.message, "table must be a list"]]

# In-range slot holding a non-callable raises (was a silent null).
nums is [42, 7]
caught_slot is ""
try:
    x is dispatch of [nums, 0, 99]
catch e:
    caught_slot is e
check of ["non-callable slot raises", contains of [caught_slot.message, "is not a function"]]

# A null slot (hole in the table) stays a silent null on both paths.
holes is [null, f1]
check of ["null slot silently null", (dispatch of [holes, 0, null]) == null]

# Non-number key raises (was a silent null on the opcode path).
caught_key is ""
try:
    x is dispatch of [t, "k", null]
catch e:
    caught_key is e
check of ["non-number key raises", contains of [caught_key.message, "key must be a number"]]

# Literal (OP_DISPATCH) and variable (builtin) forms agree on the error.
vargs is [42, 0, 7]
caught_var is ""
try:
    x is dispatch of vargs
catch e:
    caught_var is e
check of ["literal/variable forms agree", contains of [caught_var.message, "table must be a list"]]

# #459 facet 3: the parenthesized #355 form is ONE argument on the normal
# call path (never OP_DISPATCH); builtin_dispatch given a single 3-element
# list agrees with the opcode by contract — pinned here.
check of ["paren form agrees with opcode", (dispatch of ([t, 1, null])) == 20]

total is pass_count + fail_count
print of f"Dispatch Tests: {pass_count}/{total} passed"
if fail_count == 0:
    print of "All tests passed"
else:
    assert of [0, "Some dispatch tests failed"]
