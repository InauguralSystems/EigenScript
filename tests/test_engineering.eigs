# ============================================================
# Engineering Library Tests — validate every function against
#   known reference values
# ============================================================
# All expected values verified against standard engineering
# references. Tolerances chosen to accommodate floating-point
# arithmetic.

load_file of "lib/test.eigs"
load_file of "lib/engineering.eigs"

print of "=== Engineering Library Tests ==="

# ============================================================
# Unit Conversion — Temperature
# ============================================================

print of "--- Temperature Conversion ---"

# 100 C = 212 F (boiling point of water)
assert_near of [celsius_to_fahrenheit of 100, 212, 0.001, "100C to F"]

# 0 C = 32 F (freezing point of water)
assert_near of [celsius_to_fahrenheit of 0, 32, 0.001, "0C to F"]

# -40 C = -40 F (intersection point)
assert_near of [celsius_to_fahrenheit of -40, -40, 0.001, "-40C to F"]

# 212 F = 100 C
assert_near of [fahrenheit_to_celsius of 212, 100, 0.001, "212F to C"]

# 0 F = -17.778 C
assert_near of [fahrenheit_to_celsius of 0, -17.778, 0.01, "0F to C"]

# 0 C = 273.15 K
assert_near of [celsius_to_kelvin of 0, 273.15, 0.001, "0C to K"]

# 100 C = 373.15 K
assert_near of [celsius_to_kelvin of 100, 373.15, 0.001, "100C to K"]

# 273.15 K = 0 C
assert_near of [kelvin_to_celsius of 273.15, 0, 0.001, "273.15K to C"]

# ============================================================
# Unit Conversion — Length
# ============================================================

print of "--- Length Conversion ---"

# 1 meter = 3.28084 feet
assert_near of [meters_to_feet of 1, 3.28084, 0.001, "1m to ft"]

# 1 foot = 0.3048 m
assert_near of [feet_to_meters of 1, 0.3048, 0.001, "1ft to m"]

# 1 mile = 1.60934 km
assert_near of [miles_to_km of 1, 1.60934, 0.001, "1mi to km"]

# 1 km = 0.621371 miles
assert_near of [km_to_miles of 1, 0.621371, 0.001, "1km to mi"]

# ============================================================
# Unit Conversion — Mass
# ============================================================

print of "--- Mass Conversion ---"

# 1 kg = 2.20462 lbs
assert_near of [kg_to_lbs of 1, 2.20462, 0.001, "1kg to lbs"]

# 1 lb = 0.453592 kg
assert_near of [lbs_to_kg of 1, 0.453592, 0.001, "1lb to kg"]

# ============================================================
# Unit Conversion — Pressure
# ============================================================

print of "--- Pressure Conversion ---"

# 1 atm = 101325 Pa
assert_near of [atm_to_pascal of 1, 101325, 0.1, "1atm to Pa"]

# 101325 Pa = 1 atm
assert_near of [pascal_to_atm of 101325, 1, 0.0001, "101325Pa to atm"]

# 14.696 psi = 101325 Pa (1 atm)
assert_near of [psi_to_pascal of 14.696, 101325, 10, "14.696psi to Pa"]

# ============================================================
# Unit Conversion — Energy
# ============================================================

print of "--- Energy Conversion ---"

# 4.184 J = 1 calorie
assert_near of [joules_to_calories of 4.184, 1, 0.001, "4.184J to cal"]

# 1 calorie = 4.184 J
assert_near of [calories_to_joules of 1, 4.184, 0.001, "1cal to J"]

# 1 kWh = 3,600,000 J
assert_near of [kwh_to_joules of 1, 3600000, 1, "1kWh to J"]

# 1 eV = 1.602e-19 J
assert_near of [ev_to_joules of 1, 1.602176634e-19, 1e-28, "1eV to J"]

# ============================================================
# Signal Processing — DFT
# ============================================================

print of "--- Signal Processing ---"

# DFT of [1, 0, 0, 0]: X[0]=1+0i, X[1]=1+0i, X[2]=1+0i, X[3]=1+0i
# DC component (sum) = 1, all bins have magnitude 1
sig is [1, 0, 0, 0]
spec is dft of sig
assert_near of [spec[0][0], 1, 0.001, "DFT [1,0,0,0] X[0] real"]
assert_near of [spec[0][1], 0, 0.001, "DFT [1,0,0,0] X[0] imag"]
assert_near of [spec[1][0], 1, 0.001, "DFT [1,0,0,0] X[1] real"]
assert_near of [spec[2][0], 1, 0.001, "DFT [1,0,0,0] X[2] real"]
assert_near of [spec[3][0], 1, 0.001, "DFT [1,0,0,0] X[3] real"]

# DFT of constant signal [1,1,1,1]: X[0]=4, X[1]=X[2]=X[3]=0
sig2 is [1, 1, 1, 1]
spec2 is dft of sig2
assert_near of [spec2[0][0], 4, 0.001, "DFT [1,1,1,1] X[0] real = 4"]
assert_near of [spec2[1][0], 0, 0.001, "DFT [1,1,1,1] X[1] real = 0"]
assert_near of [spec2[1][1], 0, 0.001, "DFT [1,1,1,1] X[1] imag = 0"]

# Magnitude spectrum of [1,0,0,0]: all magnitudes = 1
mag is magnitude_spectrum of spec
assert_near of [mag[0], 1, 0.001, "magnitude [1,0,0,0] k=0"]
assert_near of [mag[1], 1, 0.001, "magnitude [1,0,0,0] k=1"]
assert_near of [mag[2], 1, 0.001, "magnitude [1,0,0,0] k=2"]

# Power spectrum: all powers = 1
pwr is power_spectrum of spec
assert_near of [pwr[0], 1, 0.001, "power [1,0,0,0] k=0"]

# IDFT roundtrip: IDFT(DFT([1,0,0,0])) = [1,0,0,0]
recovered is idft of spec
assert_near of [recovered[0], 1, 0.001, "IDFT roundtrip x[0]"]
assert_near of [recovered[1], 0, 0.001, "IDFT roundtrip x[1]"]
assert_near of [recovered[2], 0, 0.001, "IDFT roundtrip x[2]"]
assert_near of [recovered[3], 0, 0.001, "IDFT roundtrip x[3]"]

# Convolution: [1,2,3] * [1,1] = [1, 3, 5, 3]
conv is convolve of [[1, 2, 3], [1, 1]]
assert_near of [conv[0], 1, 0.001, "convolve [0]"]
assert_near of [conv[1], 3, 0.001, "convolve [1]"]
assert_near of [conv[2], 5, 0.001, "convolve [2]"]
assert_near of [conv[3], 3, 0.001, "convolve [3]"]

# Moving average of [1,2,3,4,5] with window 3: center values averaged
ma is moving_average of [[1, 2, 3, 4, 5], 3]
assert_near of [ma[1], 2, 0.001, "moving avg center val"]
assert_near of [ma[2], 3, 0.001, "moving avg [2]"]
assert_near of [ma[3], 4, 0.001, "moving avg [3]"]

# Decibel conversions
# 20 dB amplitude = 10x
assert_near of [amplitude_from_db of 20, 10, 0.001, "20dB to amplitude"]

# amplitude 10 = 20 dB
assert_near of [db_from_amplitude of 10, 20, 0.001, "amplitude 10 to dB"]

# power 100 = 20 dB
assert_near of [db_from_power of 100, 20, 0.001, "power 100 to dB"]

# ============================================================
# Control Systems
# ============================================================

print of "--- Control Systems ---"

# PID step: Kp=1, Ki=0.1, Kd=0.01, error=10, integral=0, prev=0, dt=0.1
# new_integral = 0 + 10*0.1 = 1
# derivative = (10-0)/0.1 = 100
# output = 1*10 + 0.1*1 + 0.01*100 = 10 + 0.1 + 1 = 11.1
pid is pid_step of [1, 0.1, 0.01, 10, 0, 0, 0.1]
assert_near of [pid[0], 11.1, 0.001, "PID output"]
assert_near of [pid[1], 1, 0.001, "PID new integral"]
assert_near of [pid[2], 10, 0.001, "PID new prev_error"]

# Transfer function poles: s^2 + 3s + 2 = 0 -> (s+1)(s+2) -> poles at -1, -2
poles is transfer_function_poles of [1, 3, 2]
assert_near of [poles[0][0], -1, 0.001, "TF pole 1 real"]
assert_near of [poles[0][1], 0, 0.001, "TF pole 1 imag"]
assert_near of [poles[1][0], -2, 0.001, "TF pole 2 real"]
assert_near of [poles[1][1], 0, 0.001, "TF pole 2 imag"]

# Complex poles: s^2 + 2s + 5 = 0 -> disc = 4-20 = -16
# poles at -1 +/- 2i
cpoles is transfer_function_poles of [1, 2, 5]
assert_near of [cpoles[0][0], -1, 0.001, "complex pole re"]
assert_near of [cpoles[0][1], 2, 0.001, "complex pole im"]
assert_near of [cpoles[1][0], -1, 0.001, "complex pole conj re"]
assert_near of [cpoles[1][1], -2, 0.001, "complex pole conj im"]

# ============================================================
# Structural Engineering
# ============================================================

print of "--- Structural Engineering ---"

# Simply supported beam: F=1000N, L=2m, E=200GPa, I=8.333e-6 m^4
# delta = 1000*8/(48*200e9*8.333e-6) = 8000/80000 = 0.0001 m = 0.1 mm
assert_near of [beam_deflection_center of [1000, 2, 200e9, 8.333e-6], 0.0001, 0.00001, "beam deflection"]

# Bending stress: M=1000 N*m, c=0.05m, I=8.333e-6 m^4
# sigma = 1000*0.05/8.333e-6 = 50/8.333e-6 = 6.0e6 Pa = 6 MPa
assert_near of [beam_max_stress of [1000, 0.05, 8.333e-6], 6.0e6, 1e4, "bending stress"]

# Rectangular moment of inertia: b=0.1m, h=0.2m
# I = 0.1*0.008/12 = 6.667e-5 m^4
assert_near of [moment_of_inertia_rect of [0.1, 0.2], 6.667e-5, 1e-7, "rect MOI"]

# Circular moment of inertia: r=0.05m
# I = pi*0.05^4/4 = pi*6.25e-6/4 = 4.909e-6 m^4  (actually pi*6.25e-8/4)
# r^4 = 6.25e-6, wait: 0.05^4 = 6.25e-6
# I = pi*6.25e-6/4 = 4.909e-6
assert_near of [moment_of_inertia_circle of 0.05, 4.909e-6, 1e-8, "circle MOI"]

# Young's modulus: stress=200e6 Pa, strain=0.001 -> E=200e9 Pa
assert_near of [youngs_modulus_stress_strain of [200e6, 0.001], 200e9, 1e6, "Youngs modulus"]

# Factor of safety: ultimate=500e6, actual=125e6 -> FOS=4
assert_near of [factor_of_safety of [500e6, 125e6], 4, 0.001, "factor of safety"]

# Euler buckling: E=200e9, I=8.333e-6, L=3
# Pcr = pi^2*200e9*8.333e-6/9 = 9.8696*200e9*8.333e-6/9
# = 9.8696*1.6666e6/9 = 16449333/9 = 1827704 N ~ 1.828e6
assert_near of [buckling_load of [200e9, 8.333e-6, 3], 1.828e6, 1e4, "Euler buckling"]

# ============================================================
# Electrical Engineering
# ============================================================

print of "--- Electrical Engineering ---"

# RC time constant: R=1000 ohm, C=1e-6 F -> tau = 0.001 s = 1 ms
assert_near of [rc_time_constant of [1000, 1e-6], 0.001, 0.0000001, "RC tau 1ms"]

# RL time constant: L=0.01 H, R=100 ohm -> tau = 0.0001 s
assert_near of [rl_time_constant of [0.01, 100], 0.0001, 0.00001, "RL tau"]

# Resonant frequency: L=1e-3 H, C=1e-6 F
# f = 1/(2*pi*sqrt(1e-9)) = 1/(2*pi*3.1623e-5) = 1/1.9869e-4 = 5032.9 Hz
assert_near of [resonant_frequency of [1e-3, 1e-6], 5032.9, 1, "LC resonance"]

# Capacitive impedance: C=10e-6 F, f=1000 Hz
# Xc = 1/(2*pi*1000*10e-6) = 1/0.06283 = 15.915 ohm
assert_near of [impedance_capacitor of [10e-6, 1000], 15.915, 0.01, "capacitor impedance"]

# Inductive impedance: L=0.01 H, f=1000 Hz
# Xl = 2*pi*1000*0.01 = 62.832 ohm
assert_near of [impedance_inductor of [0.01, 1000], 62.832, 0.01, "inductor impedance"]

# Voltage divider: Vin=12V, R1=1000, R2=2000 -> Vout = 12*2000/3000 = 8V
assert_near of [voltage_divider of [12, 1000, 2000], 8, 0.001, "voltage divider"]

# Current divider: I=6A, R1=10, R2=20 -> I1 = 6*20/30 = 4A
assert_near of [current_divider of [6, 10, 20], 4, 0.001, "current divider"]

# Power factor: P=800W, S=1000VA -> pf=0.8
assert_near of [power_factor of [800, 1000], 0.8, 0.001, "power factor"]

# Three-phase power: V=480V, I=100A, pf=0.85
# P = sqrt(3)*480*100*0.85 = 1.73205*480*100*0.85 = 70668 W
assert_near of [three_phase_power of [480, 100, 0.85], 70668, 10, "three phase power"]

# ============================================================
# Summary
# ============================================================

print of ""
test_summary of null
