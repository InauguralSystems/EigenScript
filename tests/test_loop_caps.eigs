# --- #336: break inside the 33rd nested loop exits only that loop ---
checks is checks + 1
body_n is 0
a33 is 0
a32 is 0
for v1 in range of 2:
    for v2 in range of 1:
        for v3 in range of 1:
            for v4 in range of 1:
