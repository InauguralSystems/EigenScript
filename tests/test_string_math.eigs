# Tests for string and math builtins

# pad_right / pad_left live in the string stdlib, not as builtins
load_file of "lib/string.eigs"

# ---- str_upper ----
assert of [(str_upper of "hello") == "HELLO", "SU1 basic upper"]
assert of [(str_upper of "") == "", "SU2 empty string"]
assert of [(str_upper of "ABC") == "ABC", "SU3 already upper"]

# ---- char_at ----
assert of [(char_at of ["hello", 0]) == "h", "CA1 first char"]
assert of [(char_at of ["hello", 4]) == "o", "CA2 last char"]
assert of [(char_at of ["hello", 5]) == "", "CA3 out of range"]
assert of [(char_at of ["hello", -1]) == "o", "CA4 negative index counts from the end (#312)"]

# ---- ends_with ----
assert of [(ends_with of ["hello.eigs", ".eigs"]) == 1, "EW1 match"]
assert of [(ends_with of ["hello.eigs", ".py"]) == 0, "EW2 no match"]
assert of [(ends_with of ["hi", "hello"]) == 0, "EW3 suffix longer"]

# ---- substr ----
assert of [(substr of ["hello world", 6, 5]) == "world", "SS1 basic"]
assert of [(substr of ["hello", 0, 2]) == "he", "SS2 from start"]
assert of [(substr of ["hello", 10, 2]) == "", "SS3 past end"]

# ---- index_of ----
assert of [(index_of of ["hello world", "world"]) == 6, "IO1 found"]
assert of [(index_of of ["hello world", "xyz"]) == -1, "IO2 not found"]
assert of [(index_of of ["hello", "h"]) == 0, "IO3 at start"]

# ---- pad_right (lib/string.eigs) ----
assert of [(pad_right of ["42", 6, "."]) == "42....", "PR1 pads on the right"]
assert of [(pad_right of ["hello", 3, "."]) == "hello", "PR2 already wide enough"]
assert of [(pad_right of ["", 3, "x"]) == "xxx", "PR3 empty string"]
assert of [(pad_right of ["7", 4, "0"]) == "7000", "PR4 zero pad"]

# ---- scan_ints ----
ints is scan_ints of "p cnf 3 4\n1 -2 0\nbad +7 -x 8.5 9\n"
assert of [(len of ints) == 7, "SI1 count valid integer tokens"]
assert of [ints[0] == 3, "SI2 first header count"]
assert of [ints[1] == 4, "SI3 second header count"]
assert of [ints[2] == 1, "SI4 positive literal"]
assert of [ints[3] == -2, "SI5 negative literal"]
assert of [ints[4] == 0, "SI6 zero literal"]
assert of [ints[5] == 7, "SI7 plus sign"]
assert of [ints[6] == 9, "SI8 skips malformed decimals and suffixes"]

dimacs_ints is scan_ints of ["c comment 99\n  c indented comment -4\np cnf 2 2\n1 0\n-2 0\n", "c"]
assert of [(len of dimacs_ints) == 6, "SI9 comment-line skip count"]
assert of [dimacs_ints[0] == 2, "SI10 header var count after comments"]
assert of [dimacs_ints[1] == 2, "SI11 header clause count after comments"]
assert of [dimacs_ints[2] == 1, "SI12 first clause lit"]
assert of [dimacs_ints[3] == 0, "SI13 first clause end"]
assert of [dimacs_ints[4] == -2, "SI14 second clause lit"]
assert of [dimacs_ints[5] == 0, "SI15 second clause end"]

# ---- scan_tokens ----
tokens is scan_tokens of ["c skip 99\np cnf 2 2\n1 0\n  -2 0\n", "c"]
assert of [(len of tokens) == 8, "ST1 comment-line skip token count"]
assert of [tokens[0][0] == "p", "ST2 first token text"]
assert of [tokens[0][1] == 2, "ST3 first token line"]
assert of [tokens[0][2] == 0, "ST4 first token col"]
assert of [tokens[6][0] == "-2", "ST5 signed token text"]
assert of [tokens[6][1] == 4, "ST6 signed token line"]
assert of [tokens[6][2] == 2, "ST7 signed token col"]
assert of [(substr of ["c skip 99\np cnf 2 2\n1 0\n  -2 0\n", tokens[6][3], tokens[6][4] - tokens[6][3]]) == "-2", "ST8 offsets slice token"]

# ---- scan_int_tokens ----
int_tokens_text is "c skip 99\np cnf 2 2\n1 -2 0\nbad +7 -x 8.5\n"
int_tokens is scan_int_tokens of [int_tokens_text, "c"]
assert of [(len of int_tokens) == 11, "SIT1 comment-line skip token count"]
assert of [int_tokens[0][0] == "p", "SIT2 first token text"]
assert of [int_tokens[0][5] == 0, "SIT3 p is not integer"]
assert of [int_tokens[2][5] == 1, "SIT4 header var is integer"]
assert of [int_tokens[2][6] == 2, "SIT5 header var value"]
assert of [int_tokens[4][5] == 1, "SIT6 positive lit is integer"]
assert of [int_tokens[4][6] == 1, "SIT7 positive lit value"]
assert of [int_tokens[5][6] == -2, "SIT8 negative lit value"]
assert of [int_tokens[7][5] == 0, "SIT9 bad token invalid"]
assert of [int_tokens[8][5] == 1, "SIT10 plus token valid"]
assert of [int_tokens[8][6] == 7, "SIT11 plus token value"]
assert of [(substr of [int_tokens_text, int_tokens[5][3], int_tokens[5][4] - int_tokens[5][3]]) == "-2", "SIT12 offsets slice integer token"]

# ---- sin/cos/tan ----
p is pi of null
assert of [p > 3.14, "PI1 pi > 3.14"]
assert of [p < 3.15, "PI2 pi < 3.15"]

s is sin of (p / 2)
assert of [s > 0.999, "SN1 sin(pi/2) near 1"]

c is cos of 0
assert of [c > 0.999, "CS1 cos(0) near 1"]

c2 is cos of p
assert of [c2 < -0.999, "CS2 cos(pi) near -1"]

t is tan of (p / 4)
assert of [t > 0.999, "TN1 tan(pi/4) near 1"]
assert of [t < 1.001, "TN2 tan(pi/4) near 1"]

# ---- inverse trig ----
assert of [(asin of 0) == 0, "AS1 asin(0)"]
a1 is asin of 1
assert of [a1 > 1.57, "AS2 asin(1) near pi/2"]

assert of [(acos of 1) == 0, "AC1 acos(1)"]

assert of [(atan of 0) == 0, "AT1 atan(0)"]
a2 is atan2 of [1, 1]
assert of [a2 > 0.78, "AT2 atan2(1,1) near pi/4"]

# ---- floor/ceil/round ----
assert of [(floor of 3.7) == 3, "FL1 floor"]
assert of [(floor of -2.3) == -3, "FL2 floor negative"]
assert of [(ceil of 3.2) == 4, "CL1 ceil"]
assert of [(ceil of -2.7) == -2, "CL2 ceil negative"]
assert of [(round of 3.5) == 4, "RN1 round up"]
assert of [(round of 3.4) == 3, "RN2 round down"]

# ---- abs ----
assert of [(abs of -42) == 42, "AB1 negative"]
assert of [(abs of 42) == 42, "AB2 positive"]
assert of [(abs of 0) == 0, "AB3 zero"]

# ---- min/max ----
assert of [(min of [3, 7]) == 3, "MN1 min"]
assert of [(min of [7, 3]) == 3, "MN2 min reversed"]
assert of [(max of [3, 7]) == 7, "MX1 max"]
assert of [(max of [7, 3]) == 7, "MX2 max reversed"]

# ---- string escape sequences ----
# \r escapes to ASCII CR (0x0D). Before this fix, \r fell through the
# lexer's default branch and produced the literal char 'r'. Real on-disk
# CRLF in files was always handled correctly by the scanners; the gap
# only bit anyone constructing CRLF test data inline.
crlf is "a\r\nb"
assert of [(len of crlf) == 4, "ESC1 \\r is one byte (a, CR, LF, b)"]
assert of [(substr of [crlf, 1, 1]) != "r", "ESC2 \\r is not the literal char 'r'"]
# Other escapes still work.
assert of [(len of "a\nb") == 3, "ESC3 \\n still escapes to LF"]
assert of [(len of "a\tb") == 3, "ESC4 \\t still escapes to TAB"]
assert of [(len of "a\\b") == 3, "ESC5 \\\\ still escapes to backslash"]

# ---- sign (lib/math.eigs) ----
load_file of "lib/math.eigs"
assert of [(sign of -5) == -1, "SGN1 negative"]
assert of [(sign of 0) == 0, "SGN2 zero"]
assert of [(sign of 42) == 1, "SGN3 positive"]

# ---- gcd / lcm (lib/math.eigs) ----
assert of [(gcd of [12, 18]) == 6, "GCD1 shared factor"]
assert of [(gcd of [18, 12]) == 6, "GCD2 order independence"]
assert of [(gcd of [7, 13]) == 1, "GCD3 coprime"]
assert of [(gcd of [0, 5]) == 5, "GCD4 zero a"]
assert of [(gcd of [5, 0]) == 5, "GCD5 zero b"]
assert of [(gcd of [-12, 18]) == 6, "GCD6 negative a"]
assert of [(gcd of [100, 100]) == 100, "GCD7 equal inputs"]
assert of [(lcm of [4, 6]) == 12, "LCM1 basic"]
assert of [(lcm of [6, 4]) == 12, "LCM2 order independence"]
assert of [(lcm of [0, 5]) == 0, "LCM3 zero input"]
assert of [(lcm of [7, 13]) == 91, "LCM4 coprime"]
assert of [(lcm of [3, 3]) == 3, "LCM5 equal inputs"]

# ---- capitalize (lib/string.eigs) ----
assert of [(capitalize of "hello") == "Hello", "CP1 normal word"]
assert of [(capitalize of "") == "", "CP2 empty string returns empty"]
assert of [(capitalize of "World") == "World", "CP3 already capitalized"]
assert of [(capitalize of "a") == "A", "CP4 single char"]

# ---- replace_all (lib/string.eigs) ----
assert of [(replace_all of ["abcabc", "b", "X"]) == "aXcaXc", "RA1 multiple matches"]
assert of [(replace_all of ["hello world", "world", "there"]) == "hello there", "RA2 single match"]
assert of [(replace_all of ["abc", "z", "X"]) == "abc", "RA3 no match unchanged"]
assert of [(replace_all of ["", "x", "y"]) == "", "RA4 empty source"]
# Replacement contains `find` — must not recursively re-replace or it loops forever.
assert of [(replace_all of ["a", "a", "aa"]) == "aa", "RA5 replacement contains find, no re-replace"]
# Empty `find` returns the source unchanged (documented behavior).
assert of [(replace_all of ["abc", "", "X"]) == "abc", "RA6 empty find returns source unchanged"]

print of "All string_math tests passed"
