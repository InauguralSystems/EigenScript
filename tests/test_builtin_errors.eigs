# Builtin argument-validation error paths (assert-based, catchable).
#
# Branch coverage showed builtins.c at ~60% branches-taken: most of the
# untaken branches are per-builtin argument guards that nothing in the
# suite triggers. Each case below drives one such guard with a bad
# argument, catches the resulting runtime error, and asserts its message
# substring so a missing/changed guard fails loudly instead of silently
# accepting garbage. Every error is caught, so the program exits 0 and
# prints the final marker — run via check_eigs_suite (rc + marker).
#
# Note on argument shape: a *literal* list argument of length > 1 is
# spread into positional args (issue #153), so the builtins that want a
# single list (dispatch) are fed a list held in a variable to avoid the
# spread.

# ---- set_observer_thresholds: wrong arity ----
c1 is 0
m1 is ""
try:
    set_observer_thresholds of 5
catch e:
    c1 is 1
    m1 is e
assert of [c1 == 1, "BE01 set_observer_thresholds wrong arity caught"]
assert of [(contains of [m1, "set_observer_thresholds requires"]) == 1, "BE01 message"]

# ---- set_observer_thresholds: non-positive threshold ----
c2 is 0
m2 is ""
try:
    set_observer_thresholds of [-1.0, 0.5, 0.2]
catch e:
    c2 is 1
    m2 is e
assert of [c2 == 1, "BE02 non-positive threshold caught"]
assert of [(contains of [m2, "must be positive"]) == 1, "BE02 message"]

# ---- set_observer_thresholds: dh_zero >= dh_small ----
c3 is 0
m3 is ""
try:
    set_observer_thresholds of [0.9, 0.1, 0.2]
catch e:
    c3 is 1
    m3 is e
assert of [c3 == 1, "BE03 dh_zero>=dh_small caught"]
assert of [(contains of [m3, "dh_zero must be less than dh_small"]) == 1, "BE03 message"]

# ---- load_file: non-string path ----
c4 is 0
m4 is ""
try:
    load_file of 5
catch e:
    c4 is 1
    m4 is e
assert of [c4 == 1, "BE04 load_file non-string caught"]
assert of [(contains of [m4, "load_file requires a string"]) == 1, "BE04 message"]

# ---- fill: wrong argument shape ----
c5 is 0
m5 is ""
try:
    r is fill of 5
catch e:
    c5 is 1
    m5 is e
assert of [c5 == 1, "BE05 fill wrong shape caught"]
assert of [(contains of [m5, "fill requires"]) == 1, "BE05 message"]

# ---- send: not a channel ----
c6 is 0
m6 is ""
try:
    send of [42, "x"]
catch e:
    c6 is 1
    m6 is e
assert of [c6 == 1, "BE06 send invalid channel caught"]
assert of [(contains of [m6, "invalid channel"]) == 1, "BE06 message"]

# ---- try_recv: not a channel ----
c7 is 0
m7 is ""
try:
    r is try_recv of 42
catch e:
    c7 is 1
    m7 is e
assert of [c7 == 1, "BE07 try_recv invalid channel caught"]
assert of [(contains of [m7, "invalid channel"]) == 1, "BE07 message"]

# ---- recv_timeout: not a channel ----
c8 is 0
m8 is ""
try:
    r is recv_timeout of [42, 1]
catch e:
    c8 is 1
    m8 is e
assert of [c8 == 1, "BE08 recv_timeout invalid channel caught"]
assert of [(contains of [m8, "invalid channel"]) == 1, "BE08 message"]

# ---- dispatch: wrong arity ----
c9 is 0
m9 is ""
try:
    r is dispatch of 5
catch e:
    c9 is 1
    m9 is e
assert of [c9 == 1, "BE09 dispatch wrong arity caught"]
assert of [(contains of [m9, "dispatch requires"]) == 1, "BE09 message"]

# ---- dispatch: table is not a list (variable arg to avoid list spread) ----
c10 is 0
m10 is ""
dargs1 is [42, 0, 1]
try:
    r is dispatch of dargs1
catch e:
    c10 is 1
    m10 is e
assert of [c10 == 1, "BE10 dispatch table-not-list caught"]
assert of [(contains of [m10, "table must be a list"]) == 1, "BE10 message"]

# ---- dispatch: slot is not a function ----
c11 is 0
m11 is ""
notfn is 7
dargs2 is [[notfn, notfn], 0, 5]
try:
    r is dispatch of dargs2
catch e:
    c11 is 1
    m11 is e
assert of [c11 == 1, "BE11 dispatch slot-not-fn caught"]
assert of [(contains of [m11, "is not a function"]) == 1, "BE11 message"]

# ---- nearest_in_range: wrong argument shape ----
c12 is 0
m12 is ""
try:
    r is nearest_in_range of 5
catch e:
    c12 is 1
    m12 is e
assert of [c12 == 1, "BE12 nearest_in_range wrong shape caught"]
assert of [(contains of [m12, "nearest_in_range requires"]) == 1, "BE12 message"]

# ---- nearest_in_range_all: wrong argument shape ----
c13 is 0
m13 is ""
try:
    r is nearest_in_range_all of 5
catch e:
    c13 is 1
    m13 is e
assert of [c13 == 1, "BE13 nearest_in_range_all wrong shape caught"]
assert of [(contains of [m13, "nearest_in_range_all requires"]) == 1, "BE13 message"]

print of "All builtin_errors tests passed"
