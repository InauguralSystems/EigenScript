# break/continue must not escape function call boundaries.
# (#337 update: a break/continue in a LOOP-LESS function is now a compile
# error — pinned by examples/errors/break_outside_loop.eigs and
# continue_outside_loop.eigs. The no-escape property is pinned here with
# functions that break/continue their OWN loops while the CALLER is
# looping: the callee's break must never touch the caller's loop.)

define breaker as:
    for j in [1, 2]:
        break
    return 0

define continuer as:
    for j in [1, 2]:
        continue
    return 0

# break inside called function must not break caller's loop
count is 0
for i in [1, 2, 3]:
    breaker of null
    count is count + 1
assert of [count == 3, "break inside function must not escape to caller loop"]

# continue inside called function must not skip caller's loop body
total is 0
for i in [1, 2, 3]:
    continuer of null
    total is total + i
assert of [total == 6, "continue inside function must not escape to caller loop"]

# break inside nested call must not escape through two frames
define inner_break as:
    loop while 1:
        break
    return 41

define outer_fn as:
    r is inner_break of null
    return r + 1

result is 0
for i in [1, 2, 3]:
    result is outer_fn of null
assert of [result == 42, "nested break must not escape through two function calls"]

# while loop version
count2 is 0
i is 0
loop while i < 5:
    i is i + 1
    breaker of null
    count2 is count2 + 1
assert of [count2 == 5, "break in called function must not break while loop"]

print of "break scope: all passed"
