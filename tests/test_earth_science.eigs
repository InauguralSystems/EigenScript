# ============================================================
# Earth Science Library Tests — validate every function against
#   known reference values
# ============================================================
# All expected values verified against standard geophysics and
# astronomy references. Tolerances chosen for floating-point
# arithmetic precision.

load_file of "lib/test.eigs"
load_file of "lib/earth_science.eigs"

print of "=== Earth Science Library Tests ==="

# ============================================================
# Atmospheric Science
# ============================================================

print of "--- Atmospheric Science ---"

# Barometric pressure at sea level (h=0): P = 101325 Pa
assert_near of [barometric_pressure of 0, 101325, 1, "pressure at sea level"]

# Barometric pressure at 1000 m: ~89875 Pa
assert_near of [barometric_pressure of 1000, 89875, 100, "pressure at 1000m"]

# Barometric pressure at 5000 m: ~54019 Pa
assert_near of [barometric_pressure of 5000, 54019, 200, "pressure at 5000m"]

# Temperature at sea level: 288.15 K
assert_near of [temperature_at_altitude of 0, 288.15, 0.01, "temp at sea level"]

# Temperature at 5000 m: 288.15 - 32.5 = 255.65 K = -17.5 C
assert_near of [temperature_at_altitude of 5000, 255.65, 0.01, "temp at 5000m"]

# Temperature at 11000 m (tropopause): 288.15 - 71.5 = 216.65 K
assert_near of [temperature_at_altitude of 11000, 216.65, 0.01, "temp at 11000m"]

# Dew point: T=25 C, RH=50% -> ~13.9 C (Magnus formula)
assert_near of [dew_point of [25, 50], 13.9, 0.5, "dew point 25C 50%"]

# Wind chill: T=-10 C, V=30 km/h
# WC = 13.12 + 0.6215*(-10) - 11.37*30^0.16 + 0.3965*(-10)*30^0.16
# 30^0.16 ~ 1.744
# = 13.12 - 6.215 - 11.37*1.744 + 0.3965*(-10)*1.744
# = 13.12 - 6.215 - 19.83 - 6.914 = -19.84
assert_near of [wind_chill of [-10, 30], -19.84, 1, "wind chill -10C 30km/h"]

# Air density at sea level: P=101325, T=288.15
# rho = 101325/(287.058*288.15) = 101325/82715 = 1.225 kg/m^3
assert_near of [air_density of [101325, 288.15], 1.225, 0.001, "air density sea level"]

# ============================================================
# Geology & Seismology
# ============================================================

print of "--- Geology & Seismology ---"

# Richter energy: M5 -> E = 10^(7.5+4.8) = 10^12.3 = 1.995e12 J
assert_near of [richter_energy of 5, 1.995e12, 1e11, "Richter M5 energy"]

# Richter energy: M6 -> E = 10^(9+4.8) = 10^13.8 = 6.310e13 J
assert_near of [richter_energy of 6, 6.310e13, 1e12, "Richter M6 energy"]

# Energy ratio M6/M5 = 10^1.5 = 31.62x
e5 is richter_energy of 5
e6 is richter_energy of 6
assert_near of [e6 / e5, 31.62, 0.1, "M6/M5 energy ratio"]

# Amplitude ratio: M7 vs M5 = 10^2 = 100x
assert_near of [richter_amplitude_ratio of [7, 5], 100, 0.1, "M7/M5 amplitude ratio"]

# P-wave distance: tp=10s, ts=18s -> d = 8*8 = 64 km
assert_near of [p_wave_distance of [10, 18], 64, 0.1, "P-S wave distance"]

# ============================================================
# Oceanography
# ============================================================

print of "--- Oceanography ---"

# Ocean depth from 1e7 Pa (100 atm): d = 1e7/(1025*9.80665) = 994.9 m
assert_near of [ocean_depth_from_pressure of 1e7, 994.9, 1, "ocean depth 100atm"]

# Deep water wave speed: lambda=100m
# v = sqrt(9.80665*100/(2*pi)) = sqrt(980.665/6.2832) = sqrt(156.1) = 12.49 m/s
assert_near of [wave_speed_deep of 100, 12.49, 0.1, "deep wave speed 100m"]

# Shallow water wave speed: depth=10m
# v = sqrt(9.80665*10) = sqrt(98.0665) = 9.903 m/s
assert_near of [wave_speed_shallow of 10, 9.903, 0.01, "shallow wave speed 10m"]

# Seawater density: S=35 PSU, T=20 C
# rho = 1000 + 0.8*35 - 0.004*(20-4)^2 = 1000 + 28 - 0.004*256 = 1028 - 1.024 = 1026.976
assert_near of [salinity_density of [35, 20], 1026.976, 0.01, "seawater density 35PSU 20C"]

# ============================================================
# Astronomy
# ============================================================

print of "--- Astronomy ---"

# Earth orbital period: a=1.496e11 m (1 AU), M=1.989e30 kg (Sun)
# T = 2*pi*sqrt(a^3/(GM))
# a^3 = 3.348e33, GM = 6.6743e-11*1.989e30 = 1.327e20
# a^3/GM = 3.348e33/1.327e20 = 2.523e13
# sqrt = 5.023e6, T = 2*pi*5.023e6 = 3.156e7 s
# 3.156e7 / 86400 = 365.3 days
T_earth is orbital_period of [1.496e11, 1.989e30]
T_days is T_earth / 86400
assert_near of [T_days, 365.25, 1, "Earth orbital period ~365 days"]

# Earth escape velocity: M=5.972e24 kg, R=6.371e6 m
# v = sqrt(2*6.6743e-11*5.972e24/6.371e6)
# = sqrt(2*3.986e14/6.371e6)
# = sqrt(2*62566) = sqrt(125131) wait...
# 2*G*M = 2*6.6743e-11*5.972e24 = 7.970e14
# 7.970e14/6.371e6 = 1.251e8
# sqrt(1.251e8) = 11186 m/s = 11.186 km/s
v_esc is escape_velocity of [5.972e24, 6.371e6]
assert_near of [v_esc / 1000, 11.186, 0.1, "Earth escape velocity ~11.2 km/s"]

# Earth orbital velocity: M=1.989e30 (Sun), r=1.496e11 (1 AU)
# v = sqrt(GM/r) = sqrt(1.327e20/1.496e11) = sqrt(8.87e8) = 29783 m/s
v_orb is orbital_velocity of [1.989e30, 1.496e11]
assert_near of [v_orb / 1000, 29.78, 0.1, "Earth orbital velocity ~30 km/s"]

# Schwarzschild radius of the Sun: M=1.989e30 kg
# rs = 2*G*M/c^2 = 2*6.6743e-11*1.989e30/(299792458^2)
# = 2.655e20/8.988e16 = 2953 m
assert_near of [schwarzschild_radius of 1.989e30, 2953, 5, "Sun Schwarzschild radius ~2953m"]

# Apparent magnitude: M=4.83 (Sun absolute), d=10 parsecs -> m=4.83
assert_near of [apparent_magnitude of [4.83, 10], 4.83, 0.001, "apparent mag at 10pc"]

# Apparent magnitude at 100 pc: m = 4.83 + 5*log10(10) = 4.83 + 5 = 9.83
assert_near of [apparent_magnitude of [4.83, 100], 9.83, 0.01, "apparent mag at 100pc"]

# Luminosity distance: m=9.83, M=4.83 -> d = 10^((9.83-4.83+5)/5) = 10^2 = 100 pc
assert_near of [luminosity_distance of [9.83, 4.83], 100, 0.5, "luminosity distance"]

# Stellar luminosity of the Sun: R=6.957e8 m, T=5778 K
# L = 4*pi*R^2*sigma*T^4
# R^2 = 4.84e17, 4*pi*R^2 = 6.087e18
# T^4 = 1.115e15
# sigma*T^4 = 5.67e-8*1.115e15 = 6.32e7
# L = 6.087e18*6.32e7 = 3.846e26 W
L_sun is stellar_luminosity of [6.957e8, 5778]
assert_near of [L_sun, 3.846e26, 1e24, "Sun luminosity ~3.85e26 W"]

# Hubble distance: v=7000 km/s, H0=70 km/s/Mpc -> d = 100 Mpc
assert_near of [hubble_distance of [7000, 70], 100, 0.001, "Hubble distance 100 Mpc"]

# Redshift velocity: z=0.1 -> v = c*0.1 = 2.998e7 m/s
assert_near of [redshift_velocity of 0.1, 2.998e7, 1e4, "redshift z=0.1 velocity"]

# Parallax: 1 arcsecond = 1 parsec
assert_near of [parallax_distance of 1, 1, 0.001, "1 arcsec = 1 parsec"]

# Parallax: 0.5 arcsecond = 2 parsecs
assert_near of [parallax_distance of 0.5, 2, 0.001, "0.5 arcsec = 2 parsec"]

# Parallax: 0.01 arcsecond = 100 parsecs
assert_near of [parallax_distance of 0.01, 100, 0.001, "0.01 arcsec = 100 parsec"]

# ============================================================
# Climate Science
# ============================================================

print of "--- Climate Science ---"

# CO2 radiative forcing: doubling from 280 to 560 ppm
# dF = 5.35 * ln(2) = 5.35 * 0.6931 = 3.708 W/m^2
assert_near of [co2_radiative_forcing of [560, 280], 3.708, 0.01, "CO2 doubling forcing"]

# Current CO2 ~420 ppm from pre-industrial 280 ppm
# dF = 5.35 * ln(420/280) = 5.35 * ln(1.5) = 5.35 * 0.4055 = 2.169 W/m^2
assert_near of [co2_radiative_forcing of [420, 280], 2.169, 0.01, "CO2 420ppm forcing"]

# Climate sensitivity: dF=3.7 W/m^2, dT=3 K -> lambda = 0.811
assert_near of [climate_sensitivity of [3.7, 3], 0.811, 0.01, "climate sensitivity"]

# Sea level thermal expansion: dT=1 K, depth=3700m, alpha=2.1e-4
# dh = 2.1e-4 * 3700 * 1 = 0.777 m
assert_near of [sea_level_thermal of [1, 3700, 2.1e-4], 0.777, 0.001, "sea level thermal expansion"]

# ============================================================
# Summary
# ============================================================

print of ""
test_summary of null
