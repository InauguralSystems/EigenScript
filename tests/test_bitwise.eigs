# Bitwise operation tests
load_file of "lib/test.eigs"

# AND
assert_eq of [bit_and of [0xFF, 0x0F], 15, "AND FF & 0F"]
assert_eq of [bit_and of [12, 10], 8, "AND 12 & 10"]
assert_eq of [bit_and of [7, 0], 0, "AND 7 & 0"]

# OR
assert_eq of [bit_or of [0xF0, 0x0F], 255, "OR F0 | 0F"]
assert_eq of [bit_or of [4, 2], 6, "OR 4 | 2"]
assert_eq of [bit_or of [0, 0], 0, "OR 0 | 0"]

# XOR
assert_eq of [bit_xor of [0xFF, 0x0F], 240, "XOR FF ^ 0F"]
assert_eq of [bit_xor of [5, 3], 6, "XOR 5 ^ 3"]

# Shift left
assert_eq of [bit_shl of [1, 0], 1, "SHL 1 << 0"]
assert_eq of [bit_shl of [1, 3], 8, "SHL 1 << 3"]
assert_eq of [bit_shl of [5, 2], 20, "SHL 5 << 2"]

# Shift right
assert_eq of [bit_shr of [8, 3], 1, "SHR 8 >> 3"]
assert_eq of [bit_shr of [255, 4], 15, "SHR 255 >> 4"]

# Bitmask patterns
unlocked is 0
unlocked is bit_or of [unlocked, bit_shl of [1, 0]]
unlocked is bit_or of [unlocked, bit_shl of [1, 2]]
assert_eq of [bit_and of [unlocked, 1], 1, "bitmask bit 0 set"]
assert_eq of [bit_and of [unlocked, 2], 0, "bitmask bit 1 clear"]
assert_eq of [bit_and of [unlocked, 4], 4, "bitmask bit 2 set"]

# Shift amount masking — out-of-range shifts are defined, not UB
# int64 semantics (aligned with the infix operators): counts are real
# up to 63 — the old int32-era &31 masking (1<<32 == 1) is gone.
assert_eq of [bit_shl of [1, 32], 4294967296, "SHL 1 << 32 is 2^32 (int64, no 31-masking)"]
assert_eq of [bit_shl of [1, 33], 8589934592, "SHL 1 << 33 is 2^33"]
assert_eq of [bit_shr of [8, 35], 0, "SHR 8 >> 35 shifts out to 0"]

# Out-of-range shift COUNTS are defined (masked & 63), not C UB — for BOTH the
# infix operators and the bit_* builtins. Count 64 == count 0 (64 & 63 == 0),
# count 65 == count 1, count 100 == count 36. Without the mask the infix path
# was undefined behavior (only untested counts kept UBSan quiet).
assert_eq of [1 << 64, 1, "infix << 64 masks to << 0 (defined, not UB)"]
assert_eq of [1 << 65, 2, "infix << 65 masks to << 1"]
assert_eq of [1 << 100, 68719476736, "infix << 100 masks to << 36 == 2^36"]
assert_eq of [bit_shl of [1, 64], 1, "bit_shl count 64 masks to 0 (matches infix)"]
assert_eq of [256 >> 64, 256, "infix >> 64 masks to >> 0"]

# Type safety — non-numeric args raise (strict error model, not UB, not 0).
# Builtins:
caught_and is ""
try:
    x is bit_and of ["abc", 5]
catch err:
    caught_and is err
assert_true of [contains of [caught_and, "bit_and"], "bit_and string arg raises"]

caught_or is ""
try:
    x is bit_or of [null, 5]
catch err:
    caught_or is err
assert_true of [contains of [caught_or, "bit_or"], "bit_or null arg raises"]

caught_shl is ""
try:
    x is bit_shl of [[1,2], 4]
catch err:
    caught_shl is err
assert_true of [contains of [caught_shl, "bit_shl"], "bit_shl list arg raises"]

caught_not is ""
try:
    x is bit_not of "abc"
catch err:
    caught_not is err
assert_true of [contains of [caught_not, "bit_not"], "bit_not string arg raises"]

# Operators:
caught_op_and is ""
try:
    x is "a" & 1
catch err:
    caught_op_and is err
assert_true of [contains of [caught_op_and, "cannot apply"], "& string operand raises"]

caught_op_shl is ""
try:
    x is null << 2
catch err:
    caught_op_shl is err
assert_true of [contains of [caught_op_shl, "cannot apply"], "<< null operand raises"]

caught_op_not is ""
try:
    x is ~null
catch err:
    caught_op_not is err
assert_true of [contains of [caught_op_not, "cannot apply"], "~ null operand raises"]

# --- int64 alignment: the bit_* builtins ARE the infix operators ---
# (they used to be a divergent int32 implementation: UB past 2^31 and
# sign-extended results — 0xEDB88320, CRC-32's polynomial, was the
# first casualty. Every pair below asserts builtin == infix on the
# same operands, including the high-bit range.)
assert_eq of [bit_and of [0xEDB88320, 0xFFFFFFFF], 0xEDB88320 & 0xFFFFFFFF, "AND matches infix at 2^31..2^32"]
assert_eq of [bit_and of [0xEDB88320, 0xFFFFFFFF], 0xEDB88320, "AND identity holds unsigned"]
assert_eq of [bit_xor of [0xEDB88320, 0xEDB88320], 0, "XOR self-cancels in high range"]
assert_eq of [bit_xor of [0xEDB88320, 0], 0xEDB88320, "XOR zero is identity, unsigned result"]
assert_eq of [bit_or of [0x80000000, 0x1], 0x80000001, "OR keeps bit 31 unsigned"]
assert_eq of [bit_shr of [0xEDB88320, 1], 0x76DC4190, "SHR is logical on non-negative operands"]
assert_eq of [bit_shr of [0xEDB88320, 1], 0xEDB88320 >> 1, "SHR matches infix"]
assert_eq of [bit_shl of [0x40000000, 1], 0x80000000, "SHL crosses bit 31 without sign-extending"]
assert_eq of [bit_shl of [1, 40], 1 << 40, "SHL matches infix past 32 bits"]
assert_eq of [bit_and of [bit_not of 0, 0xFFFFFFFF], 0xFFFFFFFF, "NOT of 0 masked to u32 is all-ones"]
# one CRC-32 update step, the motivating consumer shape
crc_step is bit_xor of [bit_shr of [0xFFFFFFFF, 8], 0xEDB88320]
assert_eq of [crc_step, (0xFFFFFFFF >> 8) ^ 0xEDB88320, "CRC step: builtin chain == infix chain"]

test_summary of null
