# Regression for #296: a shared helper function that gets hot (JIT-compiled)
# *on a worker thread* must not leave the chunk's jit_code dangling when that
# worker exits. The JIT emits native code into the compiling thread's per-thread
# code arena (freed at thread detach), but chunk->jit_code is one pointer on the
# shared chunk — so a worker compiling a hot shared chunk and then exiting left
# the next caller jumping into munmap'd memory (SEGV at scale). Fixed by gating
# JIT compilation off while multithreaded.
#
# Each worker calls the shared `helper` enough times to cross the JIT threshold;
# many workers run sequentially so compilation lands on a worker. No closure
# cycle, so this is leak-clean (distinct from the still-open MT cycle-GC gap).

define helper(x) as:
    return (x * 3) + 1

define worker(k) as:
    local s is 0
    local i is 0
    loop while i < 40:
        s is s + (helper of i)
        i is i + 1
    return s + k

# helper of i for i in 0..39: sum (3i+1) = 3*(0+..+39) + 40 = 3*780 + 40 = 2380
expected_base is 2380

checks is 0
passed is 0
define check(label, got, want) as:
    checks is checks + 1
    if got == want:
        passed is passed + 1
    else:
        print of ("MISMATCH " + label + ": got=" + str of got + " want=" + str of want)

n is 0
loop while n < 120:
    h is spawn of [worker, n]
    r is thread_join of h
    check of ["worker " + (str of n), r, expected_base + n]
    n is n + 1

if passed == checks:
    print of "All tests passed"
else:
    print of f"FAIL: {passed}/{checks} passed"
