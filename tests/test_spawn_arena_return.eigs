# Regression #302: a worker that returns an ARENA-allocated value (it left the
# arena active via arena_mark and never reset) must not hand the joiner freed
# memory. eigs_thread_detach runs arena_destroy; the joiner reads h->result
# strictly after that, so thread_entry now deep-copies the result to heap before
# detach (re-homing keys, like channel sends). Without the fix this is a
# cross-thread use-after-free (ASan-caught); here we also pin the values.

define worker(k) as:
    arena_mark of null                  # g_arena.active = 1 -> values built now are arena
    local r is [k, k + 1, k + 2]        # arena-allocated list (+ arena num elements)
    return r                            # deliberately no arena_reset: returns arena memory

checks is 0
passed is 0
define check(label, got, want) as:
    checks is checks + 1
    if got == want:
        passed is passed + 1
    else:
        print of ("MISMATCH " + label + ": got=" + str of got + " want=" + str of want)

# Several workers so the arena is destroyed under each before the joins read.
n is 0
loop while n < 8:
    local h is spawn of [worker, n * 10]
    local res is thread_join of h       # reads the (deep-copied) result post-detach
    check of ["len" + (str of n), len of res, 3]
    check of ["v0_" + (str of n), res[0], n * 10]
    check of ["v2_" + (str of n), res[2], (n * 10) + 2]
    n is n + 1

if passed == checks:
    print of "All tests passed"
else:
    print of f"FAIL: {passed}/{checks} passed"
