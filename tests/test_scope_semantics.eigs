# Scope semantics — assignment, shadowing, and visibility rules.
# These tests verify the "outward-mutable" assignment model and
# the interaction between scopes at different levels.

# === ASSIGNMENT IS OUTWARD-MUTABLE ===

# --- Assignment in if-block mutates outer scope ---
x is 1
if 1:
    x is 2
assert of [x == 2, "SS1 if-block assignment mutates outer"]

# --- Assignment in for-loop mutates outer scope ---
total is 0
for i in [10, 20, 30]:
    total is total + i
assert of [total == 60, "SS2 for-loop mutation of outer var"]

# --- New variable in for-loop is local, not visible outside ---
for i in [1]:
    loop_local is 99

# loop_local should not exist in outer scope — but EigenScript's
# env_set creates in the local scope if not found in parents.
# After the loop, the loop env is freed. So loop_local is gone.
caught_local is 0
try:
    x is loop_local
catch e:
    caught_local is 1
assert of [caught_local == 1, "SS3 loop-local variable is not visible outside"]

# === FUNCTION SCOPE ===

# --- Function creates its own scope ---
outer is "outer"
define shadow_test as:
    outer is "inner"
    return outer

result is shadow_test of null
assert of [result == "inner", "SS4 function sees its own assignment"]
# Tricky: does function's assignment mutate outer?
# env_set walks up — it finds 'outer' in parent and mutates it.
assert of [outer == "inner", "SS5 function assignment mutates enclosing scope"]

# --- Explicit local binding shadows instead of mutating outer ---
local_outer is "outer"
define local_shadow_test as:
    local local_outer is "inner"
    return local_outer

local_result is local_shadow_test of null
assert of [local_result == "inner", "SS5A local binding is visible in current scope"]
assert of [local_outer == "outer", "SS5B local binding does not mutate enclosing scope"]

# --- Local binding updates only the current scope ---
define local_update_test as:
    local counter is 1
    local counter is counter + 1
    return counter

assert of [local_update_test of null == 2, "SS5C local binding updates current scope"]

# --- Local binding uses the active scope; if does not create one ---
block_shadow is 10
if 1:
    local block_shadow is 20
assert of [block_shadow == 20, "SS5D local binding in if uses surrounding scope"]

# --- Local binding in a child environment does not overwrite parent ---
loop_shadow is 10
for shadow_iter in [1]:
    local loop_shadow is 20
    assert of [loop_shadow == 20, "SS5E loop-local binding shadows parent"]
assert of [loop_shadow == 10, "SS5F loop-local binding does not leak"]

# --- Function parameter shadows outer variable ---
param_val is "original"
define param_shadow(param_val) as:
    return param_val

assert of [param_shadow of "argument" == "argument", "SS6 param shadows outer"]
assert of [param_val == "original", "SS7 outer unchanged after param shadow"]

# --- Implicit `n` parameter shadows an outer `n` (issue #241) ---
# A no-param define gets one implicit parameter named `n` (see SPEC.md).
# It is a real parameter, so `n is expr` inside the body updates the
# parameter, NOT an enclosing `n` — identical to any explicit param.
n is 5
define bump_implicit_n as:
    n is 99
    return n
assert of [bump_implicit_n of 7 == 99, "SS7A implicit-n body sees its own assignment"]
assert of [n == 5, "SS7B implicit-n param does not mutate outer n"]

# The implicit parameter still binds the call argument as `n`.
define echo_implicit_n as:
    return n
assert of [echo_implicit_n of 42 == 42, "SS7C implicit-n binds the call argument"]

# Spelling the parameter explicitly as `n` is identical to the no-param form.
m is 5
define bump_explicit_n(n) as:
    n is 99
    return n
assert of [bump_explicit_n of 7 == 99, "SS7D explicit-n param sees its own assignment"]
assert of [m == 5, "SS7E unrelated outer var unchanged"]

# Contrast: a name that is NOT a parameter follows the update-outer rule.
free_name is 5
define bump_free_name as:
    free_name is 99
    return free_name
discard is bump_free_name of null
assert of [free_name == 99, "SS7F non-param name updates the enclosing binding"]

# === FOR-LOOP VARIABLE SCOPING ===

# --- Loop variable is local to each iteration ---
i is 999
for i in [1, 2, 3]:
    pass is 1
# After loop, does i retain its pre-loop value or last iteration?
# for-loop creates a child env with i as local. After loop, child is freed.
# The outer i=999 should be unchanged since the loop var is in child scope.
assert of [i == 999, "SS8 loop variable does not overwrite outer"]

# --- Nested loops with same variable name ---
results is []
for i in [1, 2]:
    for i in [10, 20]:
        append of [results, i]
assert of [len of results == 4, "SS9 nested same-name loop runs all"]
assert of [results[0] == 10, "SS10 inner loop values correct"]
assert of [results[3] == 20, "SS11 last inner value"]

# === OBSERVER TRACKING THROUGH SCOPES ===

# --- Assignment updates __observer__ ---
x is 42
obs is env_get of "__observer__"
# __observer__ should be the last assigned value
# (we can't call env_get directly, but we can check observer via report)
report_x is report of x
assert of [type of report_x == "str", "SS12 report returns string"]

# --- Assignment in function updates caller's __observer__ ---
define set_val as:
    y is 100
    return y

r is set_val of null
# The function call itself updates __observer__ via AST_RELATION

# === DICT MUTATION ACROSS SCOPES ===

# --- Dict passed to function is mutable ---
d is {"count": 0}
define bump_dict(dict) as:
    dict.count is dict.count + 1

bump_dict of d
bump_dict of d
assert of [d.count == 2, "SS13 dict mutated through function call"]

# --- List passed to function is mutable ---
lst is [0]
define push(list) as:
    append of [list, len of list]

push of lst
push of lst
push of lst
assert of [len of lst == 4, "SS14 list mutated through function call"]
assert of [lst[3] == 3, "SS15 appended values correct"]

# === #633: LISTCOMP / CATCH VAR MUST NOT DOUBLE-BIND VS A SLOT ===
# A comprehension variable (and a `catch` name) leaks into the surrounding
# scope by name (env binding). A same-named plain `x is ...` must route to
# that SAME binding, never a separate frame slot — otherwise the assignment
# writes the slot while the comprehension/catch writes the env, the two
# diverge, and later (even never-executed) code that mentions the name flips
# an earlier read's result. Invariant: program text after a statement must
# not change that statement's result.
#
# The bound names below (cv633, ev633) appear ONLY inside these functions:
# a name already live at module scope classifies as a write-through global
# and never takes the slot path, which is exactly the path that must be fixed.

# The comprehension var leaks and overwrites the earlier `cv633 is 100`.
define comp_leak as:
    cv633 is 100
    ys633 is [cv633 for cv633 in [1, 2]]
    return cv633
assert of [comp_leak of null == 2, "SS16 listcomp var leaks over an earlier plain assignment"]

# Byte-identical body plus a never-called closure that merely mentions cv633:
# it must NOT change what the earlier read of cv633 produced.
define comp_leak_dead_closure as:
    cv633 is 100
    ys633 is [cv633 for cv633 in [1, 2]]
    seen633 is cv633
    dead633 is () => cv633
    return seen633
assert of [comp_leak_dead_closure of null == 2, "SS17 a never-called closure does not change an earlier listcomp read"]

# Same double-bind class via `catch`: the caught error binds ev633 by name, so
# the earlier `ev633 is 100` slot must not survive as a stale read.
define catch_leak as:
    ev633 is 100
    try:
        boom633 is undefined_name_for_633
    catch ev633:
        noop633 is 1
    return ev633 == 100
assert of [catch_leak of null == 0, "SS18 catch name leaks over an earlier plain assignment"]

define catch_leak_dead_closure as:
    ev633 is 100
    try:
        boom633 is undefined_name_for_633
    catch ev633:
        noop633 is 1
    stale633 is ev633 == 100
    dead633 is () => ev633
    return stale633
assert of [catch_leak_dead_closure of null == 0, "SS19 a never-called closure does not change an earlier catch read"]

# SS20 (#642): the OTHER half of the double-binding defect #633's fix closed —
# and the one SS16-SS19 cannot see. Those all read the name AFTER the
# comprehension; this reads the comprehension's OWN RESULT. Before the fix the
# body resolved `i` to the shadowed slot on every iteration, so the whole list
# came out as (outer i) * 2 — [-2, -2, -2] rather than [2, 4, 6]. rc=0, no
# diagnostic, every element wrong. Distinct trigger too: #633 needs a closure
# in the body to manifest, this needs only a same-named local. Without this
# assertion a refactor could reintroduce #642 with SS16-SS19 all green.
define comp_body_shadow as:
    i642 is 0 - 1
    return [i642 * 2 for i642 in [1, 2, 3]]
comp642 is comp_body_shadow of null
assert of [comp642[0] == 2, "SS20 comprehension body sees its own loop var, not a shadowed local (#642)"]
assert of [comp642[2] == 6, "SS20b and it advances per element, rather than repeating the outer value"]

# SS21 (#642 control): the fresh-var case must keep working — a fix that
# de-promotes too eagerly would break the ordinary comprehension, and this is
# the shape every other test in the suite already uses, so nothing else would
# catch it going wrong in the other direction.
define comp_body_fresh as:
    return [j642 * 2 for j642 in [1, 2, 3]]
fresh642 is comp_body_fresh of null
assert of [fresh642[2] == 6, "SS21 a comprehension with a fresh loop var is unaffected"]

print of "scope semantics: all passed"
