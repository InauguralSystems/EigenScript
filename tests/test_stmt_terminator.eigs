# Regression for #326 — the statement terminator is enforced: leftover
# tokens after a complete statement are a parse error, not a second
# statement on the same line. Direct-source rc=1 is pinned by
# examples/errors/two_statements_one_line.eigs [90]; this file pins the
# eval / load_file surfaces, meta-interpreter parity, and positive controls.
checks is 0
passed is 0

# eval'd multi-statement line raises
checks is checks + 1
c1 is 0
try:
    eval of "x is 2 x is 3"
catch e1:
    c1 is 1
if c1 == 1:
    passed is passed + 1

# the throw-typo class: `throw "x"` (missing of) is now a parse error
checks is checks + 1
c2 is 0
try:
    eval of "throw \"bang\""
catch e2:
    c2 is 1
if c2 == 1:
    passed is passed + 1

# trailing garbage after a complete expression raises
checks is checks + 1
c3 is 0
try:
    eval of "y is 2 3"
catch e3:
    c3 is 1
if c3 == 1:
    passed is passed + 1

# #351: the member-assign statement paths missed the #326 check —
# d.a is 2 3 / l[0] is 8 9 / d.a += 5 6 all silently split (and diverged
# from the meta-interpreter, which already gated these points).
checks is checks + 1
c3a is 0
try:
    eval of "d is {\"a\": 1}\nd.a is 2 3"
catch e3a:
    c3a is 1
if c3a == 1:
    passed is passed + 1
checks is checks + 1
c3b is 0
try:
    eval of "l is [1, 2]\nl[0] is 8 9"
catch e3b:
    c3b is 1
if c3b == 1:
    passed is passed + 1
checks is checks + 1
c3c is 0
try:
    eval of "d is {\"a\": 1}\nd.a += 5 6"
catch e3c:
    c3c is 1
if c3c == 1:
    passed is passed + 1
# positive controls: legit member assigns still parse
checks is checks + 1
mv is eval of "d is {\"a\": 1}\nd.a is 2\nl is [1, 2]\nl[0] += 5\nd.a + l[0]"
if mv == 8:
    passed is passed + 1

# meta-interpreter parity: eigen_run rejects the same shape
load_file of "lib/eigen.eigs"
checks is checks + 1
c4 is 0
try:
    r4 is eigen_run of "x is 2 x is 3"
catch e4:
    c4 is 1
if c4 == 1:
    passed is passed + 1

# positive controls: normal one-statement lines are unaffected
checks is checks + 1
v is eval of "a is 1\na + 41"
if v == 42:
    passed is passed + 1
checks is checks + 1
m is eigen_run of "b is 2\nb * 3"
if m == 6:
    passed is passed + 1

if checks == passed:
    print of "All tests passed"
else:
    print of f"{passed}/{checks} passed"
