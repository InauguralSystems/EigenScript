# Additional error-path coverage (assert-based).
# Complements the substring-based error checks in run_all_tests.sh
# by exercising try/catch around runtime errors and edge-case types.
#
# These are positive tests: we expect specific behavior after an error is
# caught (or warned), not that the script aborts.

# ---- try/catch around an undefined variable ----
caught1 is 0
msg1 is ""
try:
    x is no_such_identifier_1  # lint: allow E003 -- deliberately undefined (tests the runtime error)
catch e:
    caught1 is 1
    msg1 is e
assert of [caught1 == 1, "EE01 try/catch caught undefined variable"]
assert of [(contains of [msg1.message, "undefined variable"]) == 1, "EE01 message mentions 'undefined variable'"]

# ---- try/catch around an index-out-of-range ----
caught2 is 0
msg2 is ""
try:
    items is [10, 20]
    y is items[99]
catch e:
    caught2 is 1
    msg2 is e
assert of [caught2 == 1, "EE02 try/catch caught out-of-range index"]
assert of [(contains of [msg2.message, "out of range"]) == 1, "EE02 message mentions 'out of range'"]

# ---- try/catch around indexing a number ----
caught3 is 0
msg3 is ""
try:
    n is 42
    z is n[0]
catch e:
    caught3 is 1
    msg3 is e
assert of [caught3 == 1, "EE03 try/catch caught index-on-num"]
assert of [(contains of [msg3.message, "cannot index"]) == 1, "EE03 message mentions 'cannot index'"]

# ---- try/catch around calling a non-function ----
caught4 is 0
try:
    notfn is 5
    r is notfn of 10
catch e:
    caught4 is 1
assert of [caught4 == 1, "EE04 try/catch caught call-of-non-function"]

# ---- try/catch around bad subtraction (list - num) ----
caught5 is 0
try:
    w is [1, 2] - 5
catch e:
    caught5 is 1
assert of [caught5 == 1, "EE05 try/catch caught list-minus-num"]

# ---- try/catch around bad negation ----
caught6 is 0
try:
    bad_neg is (0 - "hi")
catch e:
    caught6 is 1
assert of [caught6 == 1, "EE06 try/catch caught num-minus-string"]

# ---- Division by zero: warns but yields a value (doesn't raise) ----
# Interpreter convention: warning printed to stderr, expression evaluates to 0.
v_dz is 10 / 0
assert of [v_dz == 0, "EE07 division by zero returns 0"]

# ---- Integer 0 / 0 is also 0 ----
v_dz2 is 0 / 0
assert of [v_dz2 == 0, "EE08 0/0 returns 0"]

# ---- try/catch around throw with custom message ----
caught9 is 0
msg9 is ""
try:
    throw of "boom-custom-EE09"
catch e:
    caught9 is 1
    msg9 is e
assert of [caught9 == 1, "EE09 throw captured by try/catch"]
assert of [(contains of [msg9, "boom-custom-EE09"]) == 1, "EE09 thrown message preserved"]

# ---- Nested try/catch: inner swallows, outer doesn't see it ----
outer_caught is 0
inner_caught is 0
try:
    try:
        r is no_such_10  # lint: allow E003 -- deliberately undefined (tests the runtime error)
    catch e:
        inner_caught is 1
    # After the inner catch, execution continues normally:
    z is 42
catch e:
    outer_caught is 1
assert of [inner_caught == 1, "EE10 inner catch fired"]
assert of [outer_caught == 0, "EE10 outer catch did NOT fire"]
assert of [z == 42, "EE10 execution resumed after inner catch"]

# ---- try/catch around indexing empty list ----
caught11 is 0
try:
    empty is []
    r is empty[0]
catch e:
    caught11 is 1
assert of [caught11 == 1, "EE11 try/catch caught empty-list index"]

# ---- Error in a called function propagates to caller's try/catch ----
define propagate_fn as:
    bad is n[0]
    return bad

caught12 is 0
try:
    r is propagate_fn of 99
catch e:
    caught12 is 1
assert of [caught12 == 1, "EE12 error inside function body propagates to caller try/catch"]

# ------------------------------------------------------------------
# VM index / field / arithmetic error paths. These were the untaken
# branches dominating vm.c's low branch coverage (41% taken vs 82%
# lines): the read paths above (EE02/EE03/EE11) were covered, but the
# *assignment* index paths, the integer-index type guard, field-set on a
# non-dict, and the binop type guards for +, /, % were not exercised
# anywhere in the suite. Each error message substring is asserted so a
# changed/missing guard fails loudly.
# ------------------------------------------------------------------

# ---- non-integer index (read) ----
caught13 is 0
msg13 is ""
try:
    a13 is [1, 2, 3]
    r is a13[1.5]
catch e:
    caught13 is 1
    msg13 is e
assert of [caught13 == 1, "EE13 caught non-integer list index (read)"]
assert of [(contains of [msg13.message, "index must be an integer"]) == 1, "EE13 message mentions integer index"]

# ---- list index out of range (assignment) ----
caught14 is 0
msg14 is ""
try:
    a14 is [1, 2]
    a14[99] is 5
catch e:
    caught14 is 1
    msg14 is e
assert of [caught14 == 1, "EE14 caught out-of-range list index (assignment)"]
assert of [(contains of [msg14.message, "out of range"]) == 1, "EE14 message mentions 'out of range'"]

# ---- non-integer index (assignment) ----
caught15 is 0
msg15 is ""
try:
    a15 is [1, 2]
    a15[1.5] is 5
catch e:
    caught15 is 1
    msg15 is e
assert of [caught15 == 1, "EE15 caught non-integer list index (assignment)"]
assert of [(contains of [msg15.message, "index must be an integer"]) == 1, "EE15 message mentions integer index"]

# ---- set a field on a non-dict ----
caught16 is 0
msg16 is ""
try:
    n16 is 42
    n16.foo is 1
catch e:
    caught16 is 1
    msg16 is e
assert of [caught16 == 1, "EE16 caught field-set on a number"]
assert of [(contains of [msg16.message, "cannot set field"]) == 1, "EE16 message mentions 'cannot set field'"]

# ---- index a non-indexable for assignment ----
caught17 is 0
msg17 is ""
try:
    n17 is 42
    n17[0] is 1
catch e:
    caught17 is 1
    msg17 is e
assert of [caught17 == 1, "EE17 caught index-assignment on a number"]
assert of [(contains of [msg17.message, "cannot index"]) == 1, "EE17 message mentions 'cannot index'"]

# ---- dict indexed by a non-string key (read) ----
caught18 is 0
msg18 is ""
try:
    d18 is {"a": 1}
    r is d18[5]
catch e:
    caught18 is 1
    msg18 is e
assert of [caught18 == 1, "EE18 caught dict indexed by number (read)"]
assert of [(contains of [msg18.message, "cannot index"]) == 1, "EE18 message mentions 'cannot index'"]

# ---- dict indexed by a non-string key (assignment) ----
caught19 is 0
msg19 is ""
try:
    d19 is {"a": 1}
    d19[5] is 9
catch e:
    caught19 is 1
    msg19 is e
assert of [caught19 == 1, "EE19 caught dict indexed by number (assignment)"]
assert of [(contains of [msg19.message, "cannot index"]) == 1, "EE19 message mentions 'cannot index'"]

# ---- '+' on incompatible types ----
caught20 is 0
msg20 is ""
try:
    r is {"a": 1} + 5
catch e:
    caught20 is 1
    msg20 is e
assert of [caught20 == 1, "EE20 caught '+' on dict and num"]
assert of [(contains of [msg20.message, "cannot apply '+'"]) == 1, "EE20 message mentions cannot apply '+'"]

# ---- '/' on incompatible types ----
caught21 is 0
msg21 is ""
try:
    r is [1, 2] / 2
catch e:
    caught21 is 1
    msg21 is e
assert of [caught21 == 1, "EE21 caught '/' on list and num"]
assert of [(contains of [msg21.message, "cannot apply '/'"]) == 1, "EE21 message mentions cannot apply '/'"]

# ---- '%' on incompatible types ----
caught22 is 0
msg22 is ""
try:
    r is [1, 2] % 2
catch e:
    caught22 is 1
    msg22 is e
assert of [caught22 == 1, "EE22 caught '%' on list and num"]
assert of [(contains of [msg22.message, "cannot apply"]) == 1, "EE22 message mentions cannot apply"]

# ---- buffer index out of range ----
caught23 is 0
msg23 is ""
try:
    b23 is buffer of 4
    r is b23[99]
catch e:
    caught23 is 1
    msg23 is e
assert of [caught23 == 1, "EE23 caught buffer index out of range"]
assert of [(contains of [msg23.message, "out of range"]) == 1, "EE23 message mentions 'out of range'"]

# ---- buffer non-integer index ----
caught24 is 0
msg24 is ""
try:
    b24 is buffer of 4
    r is b24[1.5]
catch e:
    caught24 is 1
    msg24 is e
assert of [caught24 == 1, "EE24 caught non-integer buffer index"]
assert of [(contains of [msg24.message, "index must be an integer"]) == 1, "EE24 message mentions integer index"]

print of "All error_extra tests passed"
