# Regex builtin tests
load_file of "lib/test.eigs"

# match — returns [full_match, group1, ...]
result is regex_match of ["hello world", "h([a-z]+) ([a-z]+)"]
assert_eq of [result[0], "hello world", "regex full"]
assert_eq of [result[1], "ello", "regex group1"]
assert_eq of [result[2], "world", "regex group2"]

# match — no match returns empty list
empty is regex_match of ["hello", "^[0-9]+$"]
assert_eq of [len of empty, 0, "regex no match"]

# match_all — find all occurrences
nums is regex_find of ["a1 b2 c3", "[a-z][0-9]"]
assert_eq of [len of nums, 3, "match_all count"]
assert_eq of [nums[0], "a1", "match_all first"]
assert_eq of [nums[2], "c3", "match_all last"]

# match_all — no matches
empty2 is regex_find of ["hello", "[0-9]+"]
assert_eq of [len of empty2, 0, "match_all empty"]

# regex_replace — replace all
replaced is regex_replace of ["hello world", "[aeiou]", "X"]
assert_eq of [replaced, "hXllX wXrld", "regex_replace vowels"]

# regex_replace — word boundaries
cleaned is regex_replace of ["  extra   spaces  ", "  +", " "]
assert_eq of [cleaned, " extra spaces ", "regex_replace spaces"]

# regex_replace — no match leaves unchanged
same is regex_replace of ["hello", "[0-9]+", "X"]
assert_eq of [same, "hello", "regex_replace no match"]

# match with email pattern
email is regex_match of ["user@example.com", "^([a-zA-Z0-9.]+)@([a-zA-Z0-9.]+)$"]
assert_eq of [email[1], "user", "email local part"]
assert_eq of [email[2], "example.com", "email domain"]

# Extract numbers from text
prices is regex_find of ["$42 and $7 total $294", "[0-9]+"]
assert_eq of [len of prices, 3, "extract numbers count"]
assert_eq of [prices[0], "42", "extract first number"]

# ---- #629: non-participating groups keep positional indexing (null, not dropped) ----
# A leading optional group that didn't participate must NOT terminate emission.
# Python: re.match('(x)?(a)(b)', 'ab').groups() -> (None, 'a', 'b').
opt is regex_match of ["ab", "(x)?(a)(b)"]
assert_eq of [len of opt, 4, "#629 optional-lead length full+3"]
assert_eq of [opt[0], "ab", "#629 optional-lead full match"]
assert_eq of [opt[1], null, "#629 non-participating group is null"]
assert_eq of [opt[2], "a", "#629 group 2 still at index 2"]
assert_eq of [opt[3], "b", "#629 group 3 still at index 3"]

# Control: all-participating pattern is unchanged.
ctrl is regex_match of ["ab", "(a)(b)"]
assert_eq of [len of ctrl, 3, "#629 control length"]
assert_eq of [ctrl[1], "a", "#629 control group 1"]
assert_eq of [ctrl[2], "b", "#629 control group 2"]

# Non-participating group in the MIDDLE.
mid is regex_match of ["ab", "(a)(x)?(b)"]
assert_eq of [len of mid, 4, "#629 middle-optional length"]
assert_eq of [mid[1], "a", "#629 middle-optional group before"]
assert_eq of [mid[2], null, "#629 middle-optional group is null"]
assert_eq of [mid[3], "b", "#629 middle-optional group after"]

# Non-participating group at the END.
endg is regex_match of ["ab", "(a)(b)(x)?"]
assert_eq of [len of endg, 4, "#629 end-optional length"]
assert_eq of [endg[1], "a", "#629 end-optional group 1"]
assert_eq of [endg[2], "b", "#629 end-optional group 2"]
assert_eq of [endg[3], null, "#629 trailing non-participating group is null"]

# Groups past 15 no longer vanish: 17-group pattern -> full + 17 groups.
wide is regex_match of ["abcdefghijklmnopq", "(a)(b)(c)(d)(e)(f)(g)(h)(i)(j)(k)(l)(m)(n)(o)(p)(q)"]
assert_eq of [len of wide, 18, "#629 17-group pattern returns all 17 groups"]
assert_eq of [wide[16], "p", "#629 group 16 present (past old 15-cap)"]
assert_eq of [wide[17], "q", "#629 group 17 present"]

test_summary of null
