# test_dispatch_rebind_fn.eigs — #459, the function-body half of the guard:
# a plain `dispatch is ...` INSIDE a function writes through to the global
# builtin binding (in_globals in emit_assign_for_tos), so the unit scan must
# descend into function bodies. Both calls below compile on the normal call
# path: before the rebind executes, the name still resolves to the builtin
# (fail-open preserves pre-rebind semantics); after, the user fn wins.

pass_count is 0
fail_count is 0

define check(args) as:
    label is args[0]
    cond is args[1]
    if cond:
        pass_count is pass_count + 1
    else:
        fail_count is fail_count + 1
        print of ("FAIL: " + label)

define f1(x) as:
    return 20

define my3(a, b, c) as:
    return 111

define sneaky() as:
    dispatch is my3
    return 0

t is [null, f1]

# Before the fn-scope rebind runs: builtin behavior via the name path.
check of ["pre-rebind is builtin", (dispatch of [t, 1, null]) == 20]

z is sneaky of null

# After: the write-through rebind is honored.
check of ["fn-scope rebind wins", (dispatch of [t, 1, null]) == 111]

total is pass_count + fail_count
print of f"Dispatch fn-rebind tests: {pass_count}/{total} passed"
if fail_count == 0:
    print of "All tests passed"
else:
    assert of [0, "Some dispatch fn-rebind tests failed"]
