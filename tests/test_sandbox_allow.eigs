# sandbox_run is fail-CLOSED: only the pure-compute allowlist is visible; every
# other builtin is shadowed by the blocked stub. Guards (a) the residual escape
# that motivated the flip — set_observer_thresholds mutating PROCESS-GLOBAL
# observer thresholds from inside the sandbox — and (b) that the allowlist still
# lets legitimate pure compute run (no over-block). Descriptors are the same
# [code, constants] shape as vm_run_bytecode; opcodes per src/vm.h.
GET_NAME is 25
CONST is 0
CALL is 39
RETURN is 40

# (a) ESCAPE BLOCKED: set_observer_thresholds must not change host globals.
before is get_observer_thresholds of null
desc_set is [[GET_NAME,0,0, CONST,1,0, CALL,1,0, RETURN], ["set_observer_thresholds", [0.5, 0.7, 0.9]]]
r_set is sandbox_run of [desc_set, 1000]
after is get_observer_thresholds of null
escape_blocked is (r_set["ok"] == 0) and (after[0] == before[0]) and (after[1] == before[1]) and (after[2] == before[2])

# (b) Other newly-denied dangerous builtins -> blocked (ok == 0). If `exit` were
# NOT blocked it would terminate THIS process (uncatchable) — the test reaching
# the end is itself proof exit is shadowed.
screen_blk is (sandbox_run of [[[GET_NAME,0,0, CALL,0,0, RETURN], ["screen_clear"]], 1000])["ok"] == 0
exit_blk   is (sandbox_run of [[[GET_NAME,0,0, CONST,1,0, CALL,1,0, RETURN], ["exit", 0]], 1000])["ok"] == 0
seed_blk   is (sandbox_run of [[[GET_NAME,0,0, CONST,1,0, CALL,1,0, RETURN], ["seed_random", 1]], 1000])["ok"] == 0
close_blk  is (sandbox_run of [[[GET_NAME,0,0, CONST,1,0, CALL,1,0, RETURN], ["close_channel", 0]], 1000])["ok"] == 0
# #601: read_bytes_buf grew a bounded opt-in cap ([path, max_bytes]) — the
# sandbox posture must NOT widen with it: fs reads stay blocked, bounded or not.
rbb_blk    is (sandbox_run of [[[GET_NAME,0,0, CONST,1,0, CALL,1,0, RETURN], ["read_bytes_buf", "/etc/hostname"]], 1000])["ok"] == 0

# (c) ALLOWED pure compute still runs and returns the right value (no over-block).
r_len is sandbox_run of [[[GET_NAME,0,0, CONST,1,0, CALL,1,0, RETURN], ["len", "hello"]], 1000]
allow_ok is (r_len["ok"] == 1) and (r_len["result"] == 5)

if escape_blocked and screen_blk and exit_blk and seed_blk and close_blk and rbb_blk and allow_ok:
    print of "SANDBOX_ALLOW_OK"
else:
    print of "SANDBOX_ALLOW_FAIL"
    print of "escape_blocked="
    print of escape_blocked
    print of "screen/exit/seed/close/rbb="
    print of screen_blk
    print of exit_blk
    print of seed_blk
    print of close_blk
    print of rbb_blk
    print of "allow_ok="
    print of allow_ok
