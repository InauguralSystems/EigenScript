# dot reduction builtin: dot of [a, b] = sum_i a[i]*b[i].
# Association is unspecified by spec, but the VM has one deterministic
# implementation, so it must agree with an explicit left-to-right loop here.
define ref_dot(a, b, n) as:
    local s is 0
    local i is 0
    loop while i < n:
        s is s + a[i] * b[i]
        i is i + 1
    return s

ok is 1

# case 1: length 5, mixed signs
a is buffer of 5
b is buffer of 5
i is 0
loop while i < 5:
    a[i] is i * 0.5 + 1.0
    b[i] is i * 0.25 - 0.3
    i is i + 1
if (dot of [a, b]) != (ref_dot of [a, b, 5]):
    ok is 0

# case 2: integers
c is buffer of 4
d is buffer of 4
c[0] is 1
c[1] is 2
c[2] is 3
c[3] is 4
d[0] is 5
d[1] is 6
d[2] is 7
d[3] is 8
if (dot of [c, d]) != 70:
    ok is 0

# case 3: mismatched lengths use the shorter
e is buffer of 3
e[0] is 2
e[1] is 2
e[2] is 2
if (dot of [e, c]) != (1 * 2 + 2 * 2 + 3 * 2):
    ok is 0

# case 4: zero-length-overlap is 0
z is buffer of 0
if (dot of [z, c]) != 0:
    ok is 0

# case 5: sum on a buffer (was a silent 0 before the VAL_BUFFER fix)
f is buffer of 5
i is 0
loop while i < 5:
    f[i] is i * 1.5 + 1.0
    i is i + 1
if (sum of f) != (1.0 + 2.5 + 4.0 + 5.5 + 7.0):
    ok is 0

# case 6: sum still works on a list
if (sum of [1, 2, 3, 4]) != 10:
    ok is 0

# case 7: norm = L2 (3,4,0 -> 5; buffer and list agree)
g is buffer of 3
g[0] is 3
g[1] is 4
g[2] is 0
if (norm of g) != 5:
    ok is 0
if (norm of [1, 2, 2]) != 3:
    ok is 0

if ok == 1:
    print of "DOT_OK"
else:
    print of "DOT_FAIL"
