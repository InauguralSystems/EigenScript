# ============================================================
# Numerical Calculus Tests
# ============================================================
load_file of "lib/test.eigs"
import calculus

print of "=== CALCULUS TESTS ==="

# ---- Derivative ----
print of "--- Derivative ---"
# f(x) = x^2, f'(x) = 2x, f'(3) = 6
define f_sq(x) as:
    return x * x

d is calculus.derivative of [f_sq, 3, 1e-8]
assert_near of [d, 6, 1e-4, "d/dx x^2 at x=3"]

# Second derivative of x^2 = 2
d2 is calculus.second_derivative of [f_sq, 3, 1e-4]
assert_near of [d2, 2, 0.01, "d2/dx2 x^2 = 2"]

# Derivative of sin at 0 = cos(0) = 1
define f_sin(x) as:
    return sin of x

d_sin is calculus.derivative of [f_sin, 0, 1e-8]
assert_near of [d_sin, 1, 1e-4, "d/dx sin(x) at 0"]

# ---- Partial Derivative & Gradient ----
print of "--- Gradient ---"
# f(x, y) = x^2 + y^2, grad = [2x, 2y]
define f_sphere(vars) as:
    return vars[0] * vars[0] + vars[1] * vars[1]

g is calculus.gradient of [f_sphere, [3, 4], 1e-6]
assert_near of [g[0], 6, 0.01, "grad x at (3,4)"]
assert_near of [g[1], 8, 0.01, "grad y at (3,4)"]

# ---- Integration ----
print of "--- Integration ---"
# Integral of x^2 from 0 to 1 = 1/3
define f_x2(x) as:
    return x * x

trap is calculus.integrate_trapezoidal of [f_x2, 0, 1, 1000]
assert_near of [trap, 0.333333, 0.001, "trapezoidal x^2"]

simp is calculus.integrate_simpson of [f_x2, 0, 1, 100]
assert_near of [simp, 0.333333, 1e-6, "simpson x^2"]

mid is calculus.integrate_midpoint of [f_x2, 0, 1, 1000]
assert_near of [mid, 0.333333, 0.001, "midpoint x^2"]

# Simpson's rule on sin from 0 to pi = 2
pi_val is pi of null
define f_sin2(x) as:
    return sin of x

simp_sin is calculus.integrate_simpson of [f_sin2, 0, pi_val, 100]
assert_near of [simp_sin, 2, 1e-6, "simpson sin 0 to pi"]

# ---- Root Finding ----
print of "--- Root Finding ---"
# x^2 - 2 = 0 in [1,2] => sqrt(2) ~ 1.41421356
define f_sqrt2(x) as:
    return x * x - 2

root_b is calculus.bisection of [f_sqrt2, 1, 2, 1e-10]
assert_near of [root_b, 1.41421356, 1e-6, "bisection sqrt(2)"]

# Newton-Raphson for same
define df_sqrt2(x) as:
    return 2 * x

root_n is calculus.newton_raphson of [f_sqrt2, df_sqrt2, 1.5, 1e-12, 50]
assert_near of [root_n, 1.41421356, 1e-8, "newton sqrt(2)"]

# Secant method
root_s is calculus.secant_method of [f_sqrt2, 1, 2, 1e-10, 50]
assert_near of [root_s, 1.41421356, 1e-6, "secant sqrt(2)"]

# ---- Differential Equations ----
print of "--- ODEs ---"
# y' = y, y(0) = 1 => y(1) = e ~ 2.71828
define f_exp(args) as:
    return args[1]

euler_result is calculus.euler_method of [f_exp, 1, 0, 1, 1000]
euler_final is euler_result[1000]
assert_near of [euler_final[1], 2.71828, 0.01, "euler e^x"]

rk4_result is calculus.rk4_method of [f_exp, 1, 0, 1, 100]
rk4_final is rk4_result[100]
assert_near of [rk4_final[1], 2.71828, 1e-4, "rk4 e^x (much closer)"]

# RK4 system: simple harmonic oscillator y'' + y = 0
# Rewrite as system: y1' = y2, y2' = -y1
# y1(0) = 0, y2(0) = 1 => y1(t) = sin(t), y2(t) = cos(t)
define f_sho(args) as:
    t is args[0]
    y is args[1]
    return [y[1], 0 - y[0]]

sho_result is calculus.rk4_system of [f_sho, [0, 1], 0, pi_val, 200]
sho_final is sho_result[200]
# At t = pi: sin(pi) ~ 0, cos(pi) ~ -1
assert_near of [sho_final[1][0], 0, 0.001, "SHO sin(pi) ~ 0"]
assert_near of [sho_final[1][1], -1, 0.001, "SHO cos(pi) ~ -1"]

# ---- Taylor Series ----
print of "--- Taylor Series ---"
# e^1 ~ 2.71828
e_val is calculus.taylor_exp of [1, 20]
assert_near of [e_val, 2.71828, 1e-4, "taylor e^1"]

# sin(pi/2) ~ 1
s_val is calculus.taylor_sin of [pi_val / 2, 15]
assert_near of [s_val, 1, 1e-6, "taylor sin(pi/2)"]

# cos(0) = 1
c_val is calculus.taylor_cos of [0, 10]
assert_near of [c_val, 1, 1e-10, "taylor cos(0)"]

# cos(pi) = -1
c_pi is calculus.taylor_cos of [pi_val, 15]
assert_near of [c_pi, -1, 1e-6, "taylor cos(pi)"]

# ---- Interpolation ----
print of "--- Interpolation ---"
# Lagrange through (0,0), (1,1), (2,4) -> p(x) = x^2
# p(1.5) = 2.25
val is calculus.lagrange_interpolation of [[0, 1, 2], [0, 1, 4], 1.5]
assert_near of [val, 2.25, 1e-10, "lagrange x^2 at 1.5"]

# Linear interpolation
lin is calculus.linear_interpolation of [0, 0, 10, 100, 5]
assert_near of [lin, 50, 1e-10, "linear interp midpoint"]

print of ""
test_summary of null
